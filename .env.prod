APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME_genera_una_clave_aleatoria_aqui

# MySQL — cámbialo por tus credenciales de CDMON
DATABASE_URL="mysql://usuario:contraseña@localhost/nombre_bd?serverVersion=8.0&charset=utf8mb4"

# JWT — genera tus claves, NO uses las de desarrollo
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME_cambia_la_passphrase_aqui
