{% extends 'admin/layout.html.twig' %}

{# ─── Page Title ─── #}
{% block page_title %}Clients{% endblock %}

{# ─── Topbar Actions ─── #}
{% block topbar_actions %}
<a href="{{ path('admin_client_new') }}" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg"></i> Nou client
</a>
{% endblock %}

{# ─── Content ─── #}
{% block content %}

{# ─── Gradient Header (matching dashboard aesthetic) ─── #}
<div style="background: linear-gradient(160deg, rgba(73,69,255,0.08) 0%, rgba(73,69,255,0.02) 50%, transparent 100%); border-radius: var(--s-radius-lg); padding: 24px 28px; margin-bottom: 24px; border: 1px solid rgba(255,255,255,0.06);">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h5 style="color: rgba(255,255,255,0.88); font-weight: 650; letter-spacing: -0.02em; margin: 0; font-size: 1.1rem;">
                <i class="bi bi-building me-2" style="color: #4945FF;"></i>Gestió de clients
            </h5>
            <p style="color: rgba(255,255,255,0.40); font-size: 0.8rem; margin: 4px 0 0;">
                {{ stats|length }} client{{ stats|length != 1 ? 's' : '' }} registrat{{ stats|length != 1 ? 's' : '' }}
            </p>
        </div>
        <div style="font-size: 2.5rem; color: rgba(73,69,255,0.20);">
            <i class="bi bi-buildings"></i>
        </div>
    </div>
</div>

{# ─── Table: Client List ─── #}
{% if stats is empty %}
    <div class="card">
        <div class="card-body">
            <div class="empty-state">
                <i class="bi bi-building-add"></i>
                <p>No hi ha cap client encara.</p>
                <a href="{{ path('admin_client_new') }}" class="btn btn-primary btn-sm">Crear primer client</a>
            </div>
        </div>
    </div>
{% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:48px;"></th>
                        <th>Nom</th>
                        <th>Slug</th>
                        <th>Actiu</th>
                        <th>Tipus</th>
                        <th>Entrades</th>
                        <th>Usuaris</th>
                        <th>Data creació</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for stat in stats %}
                    {% set c = stat.client %}
                    <tr>
                        {# ─── Logo / Avatar ─── #}
                        <td>
                            {% if c.logo %}
                                <img src="{{ c.logo }}" alt="{{ c.name }}" style="width:40px;height:40px;object-fit:cover;border-radius:10px;display:block;">
                            {% else %}
                                <div style="width:40px;height:40px;border-radius:10px;background: linear-gradient(135deg, rgba(73,69,255,0.30) 0%, rgba(73,69,255,0.10) 100%); display:flex;align-items:center;justify-content:center; font-weight:700; font-size:0.85rem; color: rgba(73,69,255,0.70);">
                                    {{ c.name|first|upper }}
                                </div>
                            {% endif %}
                        </td>

                        {# ─── Name ─── #}
                        <td class="fw-semibold">{{ c.name }}</td>

                        {# ─── Slug ─── #}
                        <td><code>{{ c.slug }}</code></td>

                        {# ─── Active Status ─── #}
                        <td>
                            {% if c.active %}
                                <span class="badge bg-success">Actiu</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactiu</span>
                            {% endif %}
                        </td>

                        {# ─── ContentTypes count ─── #}
                        <td>{{ stat.contentTypes }}</td>

                        {# ─── Entries count ─── #}
                        <td>{{ stat.entries }}</td>

                        {# ─── Users count ─── #}
                        <td>{{ stat.users }}</td>

                        {# ─── Created date ─── #}
                        <td style="color:var(--s-text-secondary);font-size:0.75rem;">{{ c.createdAt|date('d/m/Y') }}</td>

                        {# ─── Actions ─── #}
                        <td class="text-end">
                            <a href="{{ path('admin_client_edit', {id: c.id}) }}" class="btn btn-outline-primary btn-sm" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_client_delete', {id: c.id}) }}" style="display:inline" onsubmit="return confirm('⚠️ Eliminaràs el client «{{ c.name }}» i TOTES les seves dades (tipus, entrades, usuaris, media). Aquesta acció no es pot desfer. Segur?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_client_' ~ c.id) }}">
                                <button class="btn btn-outline-danger btn-sm" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}

{% endblock %}
