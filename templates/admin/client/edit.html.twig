{% extends 'admin/layout.html.twig' %}

{# ─── Page Title ─── #}
{% block page_title %}Editar: {{ client.name }}{% endblock %}

{# ─── Topbar Actions ─── #}
{% block topbar_actions %}
<a href="{{ path('admin_client_index') }}" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-arrow-left"></i> Tornar
</a>
{% endblock %}

{# ─── Content ─── #}
{% block content %}
<div class="card">
    <div class="card-body">
        {# ─── Form Header ─── #}
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:48px;height:48px;border-radius:14px;background: linear-gradient(135deg, rgba(73,69,255,0.30) 0%, rgba(73,69,255,0.10) 100%); display:flex;align-items:center;justify-content:center; font-weight:700; font-size:1.1rem; color: rgba(73,69,255,0.70);">
                {{ client.name|first|upper }}
            </div>
            <div>
                <h6 class="mb-0">{{ client.name }}</h6>
                <span style="color:var(--s-text-secondary);font-size:0.75rem;">
                    Creat el {{ client.createdAt|date('d/m/Y') }}
                </span>
            </div>
        </div>

        {# ─── Form ─── #}
        <form method="post">
            <div class="row g-3 mb-3">
                {# ─── Name ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="nameInput">Nom *</label>
                    <input type="text" name="name" class="form-control" id="nameInput" value="{{ client.name }}" required>
                </div>

                {# ─── Slug (readonly) ─── #}
                <div class="col-md-6">
                    <label class="form-label">Slug</label>
                    <input type="text" class="form-control" value="{{ client.slug }}" disabled>
                    <div class="form-text">El slug no es pot canviar perquè s'utilitza en URLs permanents.</div>
                </div>

                {# ─── Active checkbox ─── #}
                <div class="col-12">
                    <div class="form-check">
                        <input type="checkbox" name="active" class="form-check-input" id="activeCheck" {% if client.active %}checked{% endif %} value="1">
                        <label class="form-check-label" for="activeCheck">Actiu</label>
                    </div>
                </div>
            </div>

            {# ─── Divider ─── #}
            <hr style="border-color:rgba(255,255,255,0.06);opacity:0.5;">

            {# ═══════════════════════════════════════════════════
               Usuari del client
               Es mostra l'usuari associat al client (si n'hi ha)
               i es permet canviar email, contrasenya i rol.
               ═══════════════════════════════════════════════════ #}
            <div class="d-flex align-items-center gap-3 mb-4">
                <div style="width:48px;height:48px;border-radius:14px;background: linear-gradient(135deg, rgba(73,255,150,0.30) 0%, rgba(73,255,150,0.10) 100%); display:flex;align-items:center;justify-content:center; font-size:1.2rem; color: rgba(73,255,150,0.70);">
                    <i class="bi bi-person-gear"></i>
                </div>
                <div>
                    <h6 class="mb-0">Usuari</h6>
                    <span style="color:var(--s-text-secondary);font-size:0.75rem;">
                        {% if user %}
                            {{ user.email }}
                        {% else %}
                            Cap usuari associat — crea'n un de nou
                        {% endif %}
                    </span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                {# ─── Email ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="userEmailInput">Email</label>
                    <input type="email" name="user_email" class="form-control" id="userEmailInput"
                           value="{{ user.email ?? '' }}" required placeholder="usuari@exemple.com">
                </div>

                {# ─── Password ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="userPasswordInput">Nova contrasenya</label>
                    <input type="password" name="user_password" class="form-control" id="userPasswordInput"
                           placeholder="{% if user %}Deixa en blanc per mantenir l'actual{% else %}Mínim 6 caràcters{% endif %}">
                    <div class="form-text">{% if user %}En blanc = no canvia la contrasenya actual{% endif %}</div>
                </div>

                {# ─── Rol ─── #}
                <div class="col-12">
                    <label class="form-label" for="userRoleSelect">Rol</label>
                    <select name="user_role" class="form-select" id="userRoleSelect">
                        <option value="ROLE_USUARIO" {{ user and 'ROLE_USUARIO' in user.roles ? 'selected' : '' }}>Usuari — només edita contingut, no veu seccions</option>
                        <option value="ROLE_MOD" {{ user and 'ROLE_MOD' in user.roles ? 'selected' : '' }}>Usuari Mod — edita + gestiona seccions, sense usuaris</option>
                        <option value="ROLE_ADMIN" {{ user and 'ROLE_ADMIN' in user.roles ? 'selected' : '' }}>Admin — accés complet al panell</option>
                    </select>
                    <div class="form-text">El rol determina què pot veure i fer l'usuari al panell.</div>
                </div>
            </div>

            {# ─── Divider ─── #}
            <hr style="border-color:rgba(255,255,255,0.06);opacity:0.5;">

            {# ─── Submit ─── #}
            <button type="submit" class="btn btn-primary w-100">
                <span><i class="bi bi-check-lg me-1"></i> Guardar canvis</span>
            </button>
        </form>
    </div>
</div>
{% endblock %}
