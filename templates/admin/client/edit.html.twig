{% extends 'admin/layout.html.twig' %}

{# ─── Page Title ─── #}
{% block page_title %}Editar: {{ client.name }}{% endblock %}

{# ─── Topbar Actions ─── #}
{% block topbar_actions %}
<a href="{{ path('admin_client_index') }}" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-arrow-left"></i> Tornar
</a>
{% endblock %}

{# ─── Content ─── #}
{% block content %}
<div class="card">
    <div class="card-body">
        {# ─── Form Header ─── #}
        <div class="d-flex align-items-center gap-3 mb-4">
            {# ─── Client Avatar ─── #}
            {% if client.logo %}
                <img src="{{ client.logo }}" alt="{{ client.name }}" style="width:48px;height:48px;object-fit:cover;border-radius:14px;">
            {% else %}
                <div style="width:48px;height:48px;border-radius:14px;background: linear-gradient(135deg, rgba(73,69,255,0.30) 0%, rgba(73,69,255,0.10) 100%); display:flex;align-items:center;justify-content:center; font-weight:700; font-size:1.1rem; color: rgba(73,69,255,0.70);">
                    {{ client.name|first|upper }}
                </div>
            {% endif %}
            <div>
                <h6 class="mb-0">{{ client.name }}</h6>
                <span style="color:var(--s-text-secondary);font-size:0.75rem;">
                    Creat el {{ client.createdAt|date('d/m/Y') }} · {{ client.entries|length }} entrades · {{ client.users|length }} usuaris
                </span>
            </div>
        </div>

        {# ─── Form ─── #}
        <form method="post">
            <div class="row g-3 mb-3">
                {# ─── Name ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="nameInput">Nom *</label>
                    <input type="text" name="name" class="form-control" id="nameInput" value="{{ client.name }}" required>
                </div>

                {# ─── Slug (readonly) ─── #}
                <div class="col-md-6">
                    <label class="form-label">Slug</label>
                    <input type="text" class="form-control" value="{{ client.slug }}" disabled>
                    <div class="form-text">El slug no es pot canviar perquè s'utilitza en URLs permanents.</div>
                </div>

                {# ─── Logo URL ─── #}
                <div class="col-12">
                    <label class="form-label" for="logoInput">Logo (URL)</label>
                    <input type="url" name="logo" class="form-control" id="logoInput" value="{{ client.logo }}" placeholder="https://exemple.com/logo.png">
                    <div class="form-text">Opcional. Deixa-ho en blanc per mostrar la inicial del nom.</div>
                </div>

                {# ─── Active checkbox ─── #}
                <div class="col-12">
                    <div class="form-check">
                        <input type="checkbox" name="active" class="form-check-input" id="activeCheck" {% if client.active %}checked{% endif %} value="1">
                        <label class="form-check-label" for="activeCheck">Actiu</label>
                    </div>
                    <div class="form-text">Els clients inactius no poden ser accedits pels seus usuaris administradors.</div>
                </div>
            </div>

            {# ─── Stats Overview ─── #}
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--s-radius); padding: 16px; text-align: center;">
                        <div style="font-size:1.5rem;font-weight:700;color:rgba(255,255,255,0.85);">{{ client.contentTypes|length }}</div>
                        <div style="font-size:0.7rem;color:var(--s-text-secondary);text-transform:uppercase;letter-spacing:0.05em;">Tipus de contingut</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--s-radius); padding: 16px; text-align: center;">
                        <div style="font-size:1.5rem;font-weight:700;color:rgba(255,255,255,0.85);">{{ client.entries|length }}</div>
                        <div style="font-size:0.7rem;color:var(--s-text-secondary);text-transform:uppercase;letter-spacing:0.05em;">Entrades</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--s-radius); padding: 16px; text-align: center;">
                        <div style="font-size:1.5rem;font-weight:700;color:rgba(255,255,255,0.85);">{{ client.users|length }}</div>
                        <div style="font-size:0.7rem;color:var(--s-text-secondary);text-transform:uppercase;letter-spacing:0.05em;">Usuaris</div>
                    </div>
                </div>
            </div>

            {# ─── Divider ─── #}
            <hr style="border-color:rgba(255,255,255,0.06);opacity:0.5;">

            {# ─── Submit ─── #}
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-check-lg me-1"></i> Guardar canvis
            </button>
        </form>
    </div>
</div>
{% endblock %}
