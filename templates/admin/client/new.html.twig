{% extends 'admin/layout.html.twig' %}

{# ─── Page Title ─── #}
{% block page_title %}Nou client{% endblock %}

{# ─── Topbar Actions ─── #}
{% block topbar_actions %}
<a href="{{ path('admin_client_index') }}" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-arrow-left"></i> Tornar
</a>
{% endblock %}

{# ─── Content ─── #}
{% block content %}
<div class="card">
    <div class="card-body">
        {# ─── Form Header ─── #}
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:48px;height:48px;border-radius:14px;background: linear-gradient(135deg, rgba(73,69,255,0.30) 0%, rgba(73,69,255,0.10) 100%); display:flex;align-items:center;justify-content:center; font-size:1.2rem; color: rgba(73,69,255,0.70);">
                <i class="bi bi-building-add"></i>
            </div>
            <div>
                <h6 class="mb-0">Crear nou client</h6>
                <span style="color:var(--s-text-secondary);font-size:0.75rem;">Configura les dades bàsiques del client</span>
            </div>
        </div>

        {# ─── Form ─── #}
        <form method="post">
            <div class="row g-3 mb-3">
                {# ─── Name ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="nameInput">Nom *</label>
                    <input type="text" name="name" class="form-control" id="nameInput" required placeholder="Nom del client (ex: Restaurant Can Roca)">
                </div>

                {# ─── Slug (auto-generated) ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="slugInput">Slug *</label>
                    <input type="text" name="slug" class="form-control" id="slugInput" required placeholder="restaurant_can_roca">
                    <div class="form-text">Identificador únic per URLs. Es genera automàticament des del nom.</div>
                </div>

                {# ─── Active checkbox ─── #}
                <div class="col-12">
                    <div class="form-check">
                        <input type="checkbox" name="active" class="form-check-input" id="activeCheck" checked value="1">
                        <label class="form-check-label" for="activeCheck">Actiu</label>
                    </div>
                    <div class="form-text">Els clients inactius no poden ser accedits pels seus usuaris.</div>
                </div>
            </div>

            {# ─── Divider ─── #}
            <hr style="border-color:rgba(255,255,255,0.06);opacity:0.5;">

            {# ═══════════════════════════════════════════════════
               Usuari del client
               Cada client té exactament 1 usuari. El creem aquí
               juntament amb el client per no haver de fer-ho
               des d'una secció separada.
               ═══════════════════════════════════════════════════ #}
            <div class="d-flex align-items-center gap-3 mb-4">
                <div style="width:48px;height:48px;border-radius:14px;background: linear-gradient(135deg, rgba(73,255,150,0.30) 0%, rgba(73,255,150,0.10) 100%); display:flex;align-items:center;justify-content:center; font-size:1.2rem; color: rgba(73,255,150,0.70);">
                    <i class="bi bi-person-plus"></i>
                </div>
                <div>
                    <h6 class="mb-0">Usuari</h6>
                    <span style="color:var(--s-text-secondary);font-size:0.75rem;">Crea l'usuari que gestionarà el contingut d'aquest client</span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                {# ─── Email ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="userEmailInput">Email *</label>
                    <input type="email" name="user_email" class="form-control" id="userEmailInput" required placeholder="usuari@exemple.com">
                </div>

                {# ─── Password ─── #}
                <div class="col-md-6">
                    <label class="form-label" for="userPasswordInput">Contrasenya *</label>
                    <input type="password" name="user_password" class="form-control" id="userPasswordInput" required minlength="6" placeholder="Mínim 6 caràcters">
                </div>

                {# ─── Rol ─── #}
                <div class="col-12">
                    <label class="form-label" for="userRoleSelect">Rol</label>
                    <select name="user_role" class="form-select" id="userRoleSelect">
                        <option value="ROLE_USUARIO">Usuari — només edita contingut, no veu seccions</option>
                        <option value="ROLE_MOD" selected>Usuari Mod — edita + gestiona seccions, sense usuaris</option>
                        <option value="ROLE_ADMIN">Admin — accés complet al panell</option>
                    </select>
                    <div class="form-text">Determina què pot veure i fer l'usuari dins el panell d'administració.</div>
                </div>
            </div>

            {# ─── Divider ─── #}
            <hr style="border-color:rgba(255,255,255,0.06);opacity:0.5;">

            {# ─── Submit ─── #}
            <button type="submit" class="btn btn-primary w-100">
                <span><i class="bi bi-check-lg me-1"></i> Crear client i usuari</span>
            </button>
        </form>
    </div>
</div>
{% endblock %}

{# ─── JavaScript: Auto-slug ─── #}
{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var nameInput = document.getElementById('nameInput');
    var slugInput = document.getElementById('slugInput');

    nameInput.addEventListener('input', function() {
        var slug = this.value
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/[^a-z0-9]+/g, '_')
            .replace(/^_|_$/g, '');
        slugInput.value = slug;
    });
});
</script>
{% endblock %}
