{% extends 'base.html.twig' %}

{% block title %}VoraCMS · Inici de sessió{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
<div class="s-login">
    <div class="s-login-card">
        <div class="card">
            <div class="card-body">
                <div class="s-login-brand">
                    <img src="{{ asset('img/logoVora.png') }}" alt="Vora Studio" style="height:48px;width:auto;margin:0 auto 12px;display:block;">
                    <p>Inicia sessió per continuar</p>
                </div>

                {% if error %}
                    <div class="s-toast-login">
                        <div class="s-toast-login-icon">
                            <i class="bi bi-x-lg"></i>
                        </div>
                        <div class="s-toast-login-body">
                            <div class="s-toast-login-label">Error</div>
                            <div class="s-toast-login-msg">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        </div>
                    </div>
                {% endif %}

                <form method="post">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="_username" value="{{ last_email }}" class="form-control" required autofocus placeholder="admin@vorastudio.cat">
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label">Contrasenya</label>
                        <input type="password" id="password" name="_password" class="form-control" required placeholder="········">
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><span>Entrar</span></button>
                </form>
            </div>
        </div>

        <div class="s-login-footer">
            Desenvolupat per <img src="{{ asset('img/logoVora.png') }}" alt="Vora Studio" style="height:18px;width:auto;vertical-align:middle;margin-left:4px;">
        </div>
    </div>
</div>
{% endblock %}
