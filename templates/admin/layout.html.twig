{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
<div class="s-body">

    {# ─── Sidebar ─── #}
    <nav class="s-sidebar" id="adminSidebar">
        <a class="s-sidebar-brand" href="{{ path('admin_dashboard') }}">
            <img src="{{ asset('img/logoVora.png') }}" alt="Vora Studio" class="s-sidebar-logo">
        </a>

        {# ─── Client context badge ─── #}
        {% if currentClient is defined and currentClient %}
        <div style="padding: 0 20px 16px;">
            <div style="background: rgba(73,69,255,0.10); border: 1px solid rgba(73,69,255,0.18); border-radius: 10px; padding: 10px 14px;">
                <div style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.35); margin-bottom: 4px;">Client actual</div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    {% if currentClient.logo %}
                        <img src="{{ currentClient.logo }}" alt="{{ currentClient.name }}" style="width: 24px; height: 24px; object-fit: cover; border-radius: 6px;">
                    {% else %}
                        <div style="width: 24px; height: 24px; border-radius: 6px; background: linear-gradient(135deg, rgba(73,69,255,0.40), rgba(73,69,255,0.15)); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: rgba(73,69,255,0.70);">
                            {{ currentClient.name|first|upper }}
                        </div>
                    {% endif %}
                    <span style="color: rgba(255,255,255,0.75); font-size: 0.8rem; font-weight: 600;">{{ currentClient.name }}</span>
                </div>
            </div>
        </div>
        {% endif %}

        {# ─── Navigation ─── #}
        <div class="s-sidebar-nav">
            <div class="s-sidebar-section">General</div>

            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_dashboard' %} active{% endif %}" href="{{ path('admin_dashboard') }}">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>

            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_content_type_index' %} active{% endif %}" href="{{ path('admin_content_type_index') }}">
                <i class="bi bi-layers-fill"></i> Tipus de contingut
            </a>

            {# ─── Clients link (super-admin only) ─── #}
            {% if is_granted('ROLE_SUPER_ADMIN') %}
            <a class="s-sidebar-link{% if app.request.get('_route') starts with 'admin_client_' %} active{% endif %}" href="{{ path('admin_client_index') }}">
                <i class="bi bi-building"></i> Clients
            </a>
            {% endif %}

            {% set sidebarTypes = admin_content_types() %}
            {% if sidebarTypes is not empty %}
            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_media_index' %} active{% endif %}" href="{{ path('admin_media_index') }}">
                <i class="bi bi-images"></i> Mediateca
            </a>

            <div class="s-sidebar-section">Continguts</div>
            {% for ct in sidebarTypes %}
            <a class="s-sidebar-link text-capitalize{% if app.request.get('slug') == ct.slug %} active{% endif %}" href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}">
                <i class="bi bi-file-text"></i> {{ ct.name }}
            </a>
            {% endfor %}
            {% endif %}
        </div>

        {# ─── Footer ─── #}
        <div class="s-sidebar-footer">
            <div class="dropdown dropup">
                <a class="dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle" style="font-size:1.1rem;"></i>
                    <span class="small">{{ app.user.name ?? app.user.email }}</span>
                </a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="{{ path('admin_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Tancar sessió</a></li>
                </ul>
            </div>
        </div>
    </nav>

    {# ─── Overlay (mobile) ─── #}
    <div class="s-sidebar-overlay" onclick="document.getElementById('adminSidebar').classList.toggle('open')"></div>

    {# ─── Main ─── #}
    <main class="s-main{% if app.request.get('_route') == 'admin_dashboard' %} s-main--dashboard{% endif %}">
        <div class="s-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="s-sidebar-toggle" onclick="document.getElementById('adminSidebar').classList.toggle('open')">
                    <i class="bi bi-list"></i>
                </button>
                <h1 class="s-topbar-title">{% block page_title %}VoraCMS{% endblock %}</h1>
            </div>
            <div class="s-topbar-actions">
                {% block topbar_actions %}{% endblock %}
            </div>
        </div>

        <div class="s-content">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
                    <i class="bi bi-check-circle me-1"></i> {{ message }}
                    <button type="button" class="btn-close py-2" data-bs-dismiss="alert" aria-label="Tancar"></button>
                </div>
            {% endfor %}
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
{% endblock %}
