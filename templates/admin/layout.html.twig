{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {# VoraAdmin modular stylesheets #}
    <link rel="stylesheet" href="{{ asset('css/admin/layout.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/components.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/forms.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/tables.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/dashboard.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/login.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/media.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/api-guide.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/vt-preview.css') }}?v=2.0">
    <link rel="stylesheet" href="{{ asset('css/admin/theme.css') }}?v=2.0">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="{{ asset('js/admin-animations.js') }}"></script>
    <script src="{{ asset('js/admin.js') }}"></script>
{% endblock %}

{% block body %}
<div class="s-body">

    {# ─── Sidebar ─── #}
    <nav class="s-sidebar" id="adminSidebar">
        <a class="s-sidebar-brand" href="{{ path('admin_dashboard') }}">
            <img src="{{ asset('img/logoVora.png') }}" alt="Vora Studio" class="s-sidebar-logo">
        </a>

        {# ─── Navigation ─── #}
        <div class="s-sidebar-nav">
            <div class="s-sidebar-section">General</div>

            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_dashboard' %} active{% endif %}" href="{{ path('admin_dashboard') }}">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>

            {# ─── Project selector / current project ─── #}
            {% set sidebarTypes = admin_content_types() %}
            <a class="s-sidebar-link{% if app.request.get('_route') starts with 'admin_project_' %} active{% endif %}" href="{{ path('admin_projects') }}">
                <i class="bi bi-folder"></i> Projectes
            </a>
            {% if is_granted('ROLE_ADMIN') %}
            <a class="s-sidebar-link{% if app.request.get('_route') starts with 'admin_user_' %} active{% endif %}" href="{{ path('admin_user_index') }}">
                <i class="bi bi-people"></i> Usuaris
            </a>
            {% endif %}

            {# ─── Seccions (gestió de tipus de contingut i plantilles globals) ─── #}
            {% if activeProject is defined and activeProject and is_granted('ROLE_ADMIN') %}
            <a class="s-sidebar-link{% if app.request.get('_route') starts with 'admin_content_type_' or app.request.get('_route') starts with 'admin_base_content_' %} active{% endif %}" href="{{ path('admin_content_type_index') }}">
                <i class="bi bi-layers-fill"></i> Tipus de contingut
            </a>
            {% endif %}

            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_media_index' %} active{% endif %}" href="{{ path('admin_media_index') }}">
                <i class="bi bi-images"></i> Mediateca
            </a>

            {# ─── Si hi ha projecte actiu → mostrem les seves seccions ─── #}
            {% if sidebarTypes is not empty %}
            <div class="s-sidebar-section">
                {% if activeProject is defined and activeProject %}
                    {{ activeProject.name }}
                {% else %}
                    Continguts
                {% endif %}
            </div>
            {% for ct in sidebarTypes %}
            <a class="s-sidebar-link text-capitalize{% if app.request.get('slug') == ct.slug %} active{% endif %}" href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}">
                <i class="bi bi-file-text"></i> {{ ct.name }}
            </a>
            {% endfor %}
            {% endif %}

            {% if is_granted('ROLE_ADMIN') %}
            <div class="s-sidebar-section">Desenvolupador</div>
            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_api_guide' %} active{% endif %}" href="{{ path('admin_api_guide') }}">
                <i class="bi bi-code-slash"></i> Guia API
            </a>
            <a class="s-sidebar-link s-sidebar-link--sub{% if app.request.get('_route') == 'admin_api_guide_security' %} active{% endif %}" href="{{ path('admin_api_guide_security') }}">
                <i class="bi bi-shield-check"></i> Seguretat
            </a>
            {% endif %}

        </div>{# ─── /s-sidebar-nav ─── #}
    </nav>

    {# ─── Overlay (mobile) ─── #}
    <div class="s-sidebar-overlay"></div>

    {# ─── Main ─── #}
    <main class="s-main{% if app.request.get('_route') == 'admin_dashboard' %} s-main--dashboard{% endif %}">
        <div class="s-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="s-sidebar-toggle">
                    <i class="bi bi-list"></i>
                </button>
                <h1 class="s-topbar-title">{% block page_title %}VoraCMS{% endblock %}</h1>
            </div>
            <div class="s-topbar-actions">
                {# ─── Theme toggle ─── #}
                <button class="s-theme-toggle" id="themeToggle" title="Canviar tema">
                    <i class="bi bi-sun-fill s-theme-icon-light"></i>
                    <i class="bi bi-moon-fill s-theme-icon-dark"></i>
                </button>
                {# ─── User card ─── #}
                {% include 'admin/_user_card.html.twig' %}
            </div>
        </div>

        {# ─── Action Bar (just a sota del topbar) ─── #}
        <div class="s-action-bar">
            {% block topbar_actions %}{% endblock %}
        </div>

        <div class="s-content">
            {% block content %}{% endblock %}
        </div>

        <div class="s-footer">
            Desenvolupat per <img src="{{ asset('img/logoVora.png') }}" alt="Vora Studio">
        </div>
    </main>
</div>

{# ─── Flash messages → SweetAlert toasts ─── #}
<div id="flashData" class="flash-data"
     data-flash='{
         "success": [
             {% for msg in app.flashes('success') %}
                 {{ msg|json_encode|raw }}{{ loop.last ? '' : ',' }}
             {% endfor %}
         ],
         "error": [
             {% for msg in app.flashes('error') %}
                 {{ msg|json_encode|raw }}{{ loop.last ? '' : ',' }}
             {% endfor %}
         ],
         "warning": [
             {% for msg in app.flashes('warning') %}
                 {{ msg|json_encode|raw }}{{ loop.last ? '' : ',' }}
             {% endfor %}
         ],
         "info": [
             {% for msg in app.flashes('info') %}
                 {{ msg|json_encode|raw }}{{ loop.last ? '' : ',' }}
             {% endfor %}
         ]
     }'></div>
{% endblock %}
