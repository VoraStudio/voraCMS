{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="{{ asset('js/admin-animations.js') }}"></script>
    <script>
    function swalConfirm(msg, cb) {
        Swal.fire({
            html: '<div class="swal-icon-wrap"><div class="swal-icon-inner"><i class="bi bi-exclamation-triangle"></i></div></div><p class="swal-msg">' + msg + '</p>',
            showCancelButton: true,
            confirmButtonText: 'Eliminar',
            cancelButtonText: 'Cancel·lar',
            confirmButtonColor: '#DC2626',
            reverseButtons: true,
            background: 'linear-gradient(135deg, rgba(18,22,55,0.98), rgba(12,15,40,0.98))',
            backdrop: 'rgba(0,0,0,0.65)',
            color: 'rgba(255,255,255,0.90)',
            padding: '32px 28px 28px',
            width: '420px',
            showClass: {
                popup: 'swal-popup-in'
            },
            hideClass: {
                popup: 'swal-popup-out'
            },
            customClass: {
                popup: 'swal-popup-custom',
                confirmButton: 'btn btn-sm px-4 swal-confirm-btn',
                cancelButton: 'btn btn-outline-secondary btn-sm px-4',
                htmlContainer: 'swal-html-custom',
                actions: 'swal-actions-custom',
            },
            buttonsStyling: false,
        }).then(function(result) {
            if (result.isConfirmed && cb) cb();
        });
    }
    </script>
{% endblock %}

{% block body %}
<div class="s-body">

    {# ─── Sidebar ─── #}
    <nav class="s-sidebar" id="adminSidebar">
        <a class="s-sidebar-brand" href="{{ path('admin_dashboard') }}">
            <img src="{{ asset('img/logoVora.png') }}" alt="Vora Studio" class="s-sidebar-logo">
        </a>

        {# ─── Navigation ─── #}
        <div class="s-sidebar-nav">
            <div class="s-sidebar-section">General</div>

            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_dashboard' %} active{% endif %}" href="{{ path('admin_dashboard') }}">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>

            {# ─── Project selector / current project ─── #}
            {% set sidebarTypes = admin_content_types() %}
            {% if is_granted('ROLE_ADMIN') %}
            <a class="s-sidebar-link{% if app.request.get('_route') starts with 'admin_project_' %} active{% endif %}" href="{{ path('admin_projects') }}">
                <i class="bi bi-folder"></i> Projectes
            </a>
            {% endif %}

            {% if activeProject is defined and activeProject %}
            <div class="s-sidebar-section" style="padding-left:20px;">
                <span style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;">
                    {{ activeProject.name }}
                </span>
            </div>
            {% endif %}

            {# ─── Seccions (gestió de tipus de contingut) ─── #}
            {% if activeProject is defined and activeProject and is_granted('MANAGE_CT', activeProject) %}
            <a class="s-sidebar-link{% if app.request.get('_route') starts with 'admin_content_type_' %} active{% endif %}" href="{{ path('admin_content_type_index') }}">
                <i class="bi bi-layers-fill"></i> Tipus de contingut
            </a>
            {% endif %}

            <a class="s-sidebar-link{% if app.request.get('_route') == 'admin_media_index' %} active{% endif %}" href="{{ path('admin_media_index') }}">
                <i class="bi bi-images"></i> Mediateca
            </a>

            {# ─── Si hi ha projecte actiu → mostrem les seves seccions ─── #}
            {% if sidebarTypes is not empty %}
            <div class="s-sidebar-section">Continguts</div>
            {% for ct in sidebarTypes %}
            <a class="s-sidebar-link text-capitalize{% if app.request.get('slug') == ct.slug %} active{% endif %}" href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}">
                <i class="bi bi-file-text"></i> {{ ct.name }}
            </a>
            {% endfor %}
            {% endif %}

        </div>{# ─── /s-sidebar-nav ─── #}
    </nav>

    {# ─── Overlay (mobile) ─── #}
    <div class="s-sidebar-overlay" onclick="document.getElementById('adminSidebar').classList.toggle('open')"></div>

    {# ─── Main ─── #}
    <main class="s-main{% if app.request.get('_route') == 'admin_dashboard' %} s-main--dashboard{% endif %}">
        <div class="s-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="s-sidebar-toggle" onclick="document.getElementById('adminSidebar').classList.toggle('open')">
                    <i class="bi bi-list"></i>
                </button>
                <h1 class="s-topbar-title">{% block page_title %}VoraCMS{% endblock %}</h1>
            </div>
            <div class="s-topbar-actions">
                {# ─── Theme toggle ─── #}
                <button class="s-theme-toggle" id="themeToggle" title="Canviar tema">
                    <i class="bi bi-sun-fill s-theme-icon-light"></i>
                    <i class="bi bi-moon-fill s-theme-icon-dark"></i>
                </button>
                {# ─── User card ─── #}
                {% include 'admin/_user_card.html.twig' %}
            </div>
        </div>

        {# ─── Action Bar (just a sota del topbar) ─── #}
        <div class="s-action-bar">
            {% block topbar_actions %}{% endblock %}
        </div>

        <div class="s-content">
            {% block content %}{% endblock %}
        </div>

        <div class="s-footer">
            Desenvolupat per <img src="{{ asset('img/logoVora.png') }}" alt="Vora Studio">
        </div>
    </main>
</div>

{# ─── Toast container flotant ─── #}
<div class="toast-container position-fixed bottom-0 end-0 p-4" id="flashToasts" style="z-index: 9999;">
    {% set toastConfig = {
        'success': { icon: 'bi-check-lg',     color: '#4CAF50', grad: '135deg,#2E7D32,#4CAF50', label: 'Fet' },
        'error':   { icon: 'bi-x-lg',         color: '#EF5350', grad: '135deg,#C62828,#EF5350', label: 'Error' },
        'warning': { icon: 'bi-dash-lg',      color: '#FFB74D', grad: '135deg,#E65100,#FFB74D', label: 'Avís' },
        'info':    { icon: 'bi-info-lg',      color: '#60A5FA', grad: '135deg,#1565C0,#60A5FA', label: 'Info' },
    } %}
    {% for type in ['success', 'error', 'warning', 'info'] %}
        {% set cfg = toastConfig[type] %}
        {% for message in app.flashes(type) %}
        <div class="toast mb-3" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4500"
             style="min-width:360px;max-width:440px;background:linear-gradient({{ cfg.grad }});border:none;border-radius:14px;box-shadow:0 8px 40px {{ cfg.color }}44,0 2px 8px rgba(0,0,0,0.20);padding:0;overflow:hidden;">
            <div class="d-flex align-items-center" style="padding:16px 18px;gap:14px;">
                <div style="width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,0.18);display:flex;align-items:center;justify-content:center;flex-shrink:0;backdrop-filter:blur(4px);">
                    <i class="bi {{ cfg.icon }}" style="color:#fff;font-size:1.1rem;font-weight:700;"></i>
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="color:#fff;font-size:0.82rem;font-weight:600;line-height:1.3;margin-bottom:3px;">{{ cfg.label }}</div>
                    <div style="color:rgba(255,255,255,0.80);font-size:0.8rem;font-weight:400;line-height:1.4;">{{ message }}</div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Tancar" style="font-size:0.55rem;opacity:0.4;flex-shrink:0;filter:none;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='0.4'"></button>
            </div>
        </div>
        {% endfor %}
    {% endfor %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ─── Toasts ───
    var toastElList = [].slice.call(document.querySelectorAll('#flashToasts .toast'));
    toastElList.forEach(function(el) {
        var toast = new bootstrap.Toast(el);
        toast.show();
    });

    // ─── Theme Toggle ───
    var html = document.documentElement;
    var toggle = document.getElementById('themeToggle');
    var saved = localStorage.getItem('voracms_theme');

    if (saved === 'light') {
        html.setAttribute('data-theme', 'light');
    }

    if (toggle) {
        toggle.addEventListener('click', function () {
            var isLight = html.getAttribute('data-theme') === 'light';
            if (isLight) {
                html.removeAttribute('data-theme');
                localStorage.setItem('voracms_theme', 'dark');
            } else {
                html.setAttribute('data-theme', 'light');
                localStorage.setItem('voracms_theme', 'light');
            }
        });
    }
});
</script>
{% endblock %}
