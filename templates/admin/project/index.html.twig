{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ filterUser is defined and filterUser ? filterUser.name : 'Projectes' }}{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_project_new') }}" class="cyber-btn-primary" data-anim="cyber-btn">
    <i class="bi bi-plus-lg"></i> <span>Nou projecte</span>
</a>
{% endblock %}

{% block content %}

{# ─── User filter header ─── #}
{% if filterUser is defined and filterUser %}
<div class="cyber-section-header" data-anim="cyber-card" style="margin-bottom:24px;">
    <div class="cyber-section-header-left">
        <div class="cyber-section-icon">
            <i class="bi bi-person-fill"></i>
        </div>
        <div>
            <h2 class="cyber-section-title">{{ filterUser.name }}</h2>
            <p class="cyber-section-desc">Projectes i seccions</p>
        </div>
    </div>
    <div class="cyber-section-header-right">
        <div class="cyber-stat-mini">
            <span class="cyber-stat-mini-value">{{ mainProject ? mainProject.contentTypes|length : 0 }}</span>
            <span class="cyber-stat-mini-label">Seccions</span>
        </div>
        <div class="cyber-stat-mini">
            <span class="cyber-stat-mini-value">{{ otherProjects|length }}</span>
            <span class="cyber-stat-mini-label">Projectes</span>
        </div>
        <a href="{{ path('admin_projects') }}" class="cyber-btn-back" style="margin-left:8px;" title="Tornar a tots els projectes">
            <i class="bi bi-x-lg"></i> <span>Netejar</span>
        </a>
    </div>
</div>

{% if mainProject %}
    {# ─── Main project section header ─── #}
    {% set color = mainProject.color ?: '#06B6D4' %}
    <div class="cyber-card" data-anim="cyber-card" style="padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;gap:16px;">
        <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:8px;height:8px;border-radius:50%;background:{{ color }};flex-shrink:0;"></div>
            <div>
                <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--s-text-secondary);opacity:0.75;margin-bottom:1px;">Projecte principal</div>
                <div style="font-size:0.95rem;font-weight:600;color:var(--s-text);">{{ mainProject.name }}</div>
            </div>
        </div>
        <div style="display:flex;gap:8px;">
            <a href="{{ path('admin_project_edit', {id: mainProject.id}) }}" class="cyber-btn cyber-btn--icon cyber-btn--edit" title="Editar projecte">
                <i class="bi bi-pencil"></i>
            </a>
            <a href="{{ path('admin_switch_project', {id: mainProject.id}) }}" class="cyber-btn-primary" style="padding:8px 16px;font-size:0.7rem;">
                <i class="bi bi-arrow-right-circle"></i> <span>Obrir</span>
            </a>
        </div>
    </div>

    {# ─── Content type cards ─── #}
    <div class="row g-3 project-cards-grid" style="margin-bottom:32px;">
        {% for ct in mainProject.contentTypes %}
        {% set icon = 'bi-file-earmark' %}
        {% set entriesCount = ct.entries|length %}
        <div class="col-md-6 col-lg-4">
            <div class="cyber-card project-content-card" data-anim="cyber-card" style="cursor:pointer;padding:24px 24px 20px;display:flex;flex-direction:column;"
                 onclick="window.location='{{ path('admin_entry_by_type', {slug: ct.slug}) }}'">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;flex-shrink:0;">
                    <div class="cyber-section-icon" style="width:48px;height:48px;border-radius:14px;font-size:1.2rem;margin:0;">
                        <i class="bi {{ icon }}"></i>
                    </div>
                    <span class="cyber-badge {{ entriesCount > 0 ? 'cyber-badge--mod' : '' }}" style="font-size:0.6rem;flex-shrink:0;">
                        {{ entriesCount }} entrades
                    </span>
                </div>
                <div style="flex:1;display:flex;flex-direction:column;">
                    <h3 style="font-size:0.95rem;font-weight:700;margin:0 0 4px;color:var(--s-text);">{{ ct.name }}</h3>
                    {% if ct.description %}
                    <p style="font-size:0.75rem;color:var(--s-text-secondary);margin:0;line-height:1.4;flex:1;">{{ ct.description }}</p>
                    {% endif %}
                </div>
                <a href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}" class="cyber-btn cyber-btn--projects" style="font-size:0.6rem;padding:5px 12px;margin-top:12px;flex-shrink:0;align-self:flex-start;">
                    <i class="bi bi-eye"></i> <span>Veure entrades</span>
                </a>
            </div>
        </div>
        {% else %}
        <div class="col-12">
            <div class="cyber-card" data-anim="cyber-card" style="text-align:center;padding:40px 24px;">
                <div style="font-size:2.5rem;color:rgba(148,163,184,0.15);margin-bottom:12px;">
                    <i class="bi bi-layers"></i>
                </div>
                <p style="color:var(--s-text-secondary);font-size:0.85rem;margin:0 0 16px;">Aquest projecte no té seccions encara</p>
                <a href="{{ path('admin_switch_project', {id: mainProject.id}) }}" class="cyber-btn-primary" style="font-size:0.7rem;padding:8px 16px;">
                    <i class="bi bi-plus-lg"></i> <span>Crear secció</span>
                </a>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}

{# ─── Other projects ─── #}
{% if otherProjects|length > 0 %}
<h4 style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--s-text-secondary);opacity:0.75;margin:0 0 14px;">
    <i class="bi bi-folder2-open" style="margin-right:6px;"></i> Altres projectes
</h4>
<div class="row g-3 project-cards-grid">
    {% for project in otherProjects %}
    {% set color = project.color ?: '#4945FF' %}
    <div class="col-md-6 col-lg-4">
        <div class="cyber-card project-other-card" data-anim="cyber-card"
             style="cursor:pointer;padding:20px 24px;border-left:3px solid {{ color }};display:flex;align-items:center;"
             onclick="window.location='{{ path('admin_switch_project', {id: project.id}) }}'">
            <div style="display:flex;align-items:center;gap:14px;width:100%;">
                <div class="project-other-icon" style="width:42px;height:42px;border-radius:12px;background:rgba(148,163,184,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:{{ color }};font-size:1.2rem;">
                    <i class="bi bi-folder2-open"></i>
                </div>
                <div style="flex:1;min-width:0;">
                    <div class="project-other-name" style="font-size:0.9rem;font-weight:600;color:var(--s-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ project.name }}</div>
                    <div style="font-size:0.65rem;color:var(--s-text-secondary);margin-top:3px;">
                        {{ project.contentTypes|length }} seccions · {{ project.contentTypes|reduce((carry, ct) => carry + ct.entries|length, 0) }} entrades
                    </div>
                </div>
                <i class="bi bi-chevron-right" style="color:rgba(148,163,184,0.3);font-size:0.9rem;"></i>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{% elseif projects is defined %}
{# ─── All projects view (grouped by client) ─── #}
<div class="cyber-section-header" data-anim="cyber-card">
    <div class="cyber-section-header-left">
        <div class="cyber-section-icon">
            <i class="bi bi-folder2-open"></i>
        </div>
        <div>
            <h2 class="cyber-section-title">Projectes</h2>
            <p class="cyber-section-desc">Gestiona els projectes i el seu contingut</p>
        </div>
    </div>
    <div class="cyber-section-header-right">
        <div class="cyber-stat-mini">
            <span class="cyber-stat-mini-value">{{ projects|length }}</span>
            <span class="cyber-stat-mini-label">Total</span>
        </div>
        <div class="cyber-stat-mini">
            <span class="cyber-stat-mini-value cyber-stat-mini-value--active">{{ projects|filter(p => p.active)|length }}</span>
            <span class="cyber-stat-mini-label">Actius</span>
        </div>
    </div>
</div>

{% set currentUserId = -1 %}
{% for project in projects %}
{% set pid = project.user ? project.user.id : 0 %}

{% if pid != currentUserId %}
  {% set currentUserId = pid %}
  {% if not loop.first %}</tbody></table></div>{% endif %}

  {# ─── Client group header ─── #}
  <div class="cyber-card cyber-card--table" data-anim="cyber-card" style="padding:0;overflow:hidden;margin-bottom:24px;">
    <div style="padding:12px 20px;border-bottom:1px solid rgba(148,163,184,0.08);display:flex;align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div class="cyber-avatar" style="width:28px;height:28px;font-size:0.65rem;">{{ project.user ? project.user.name|first|upper : '?' }}</div>
        <div>
          <span style="font-size:0.82rem;font-weight:700;color:var(--s-text);">{{ project.user ? project.user.name : 'Sense client' }}</span>
          {% if project.user %}
          <span style="font-size:0.6rem;color:var(--s-text-secondary);margin-left:8px;">{{ project.user.email }}</span>
          {% endif %}
        </div>
      </div>
      <span style="font-size:0.72rem;font-weight:600;color:var(--s-text-secondary);opacity:0.9;letter-spacing:0.05em;">
        {{ projects|filter(p => (p.user ? p.user.id : 0) == pid)|length }} projectes
      </span>
    </div>
    <table class="cyber-table cyber-table--projects">
      <thead>
        <tr>
          <th style="width: 35%;">Projecte</th>
          <th style="width: 12%;">Seccions</th>
          <th style="width: 12%;">Entrades</th>
          <th style="width: 15%;">Estat</th>
          <th style="width: 26%;">Accions</th>
        </tr>
      </thead>
      <tbody>
{% endif %}

        {% set color = project.color ?: '#4945FF' %}
        <tr class="cyber-row {{ project.active ? 'row-active' : 'row-inactive' }}" data-anim="cyber-row" style="cursor:pointer;" onclick="window.location='{{ path('admin_switch_project', {id: project.id}) }}'">
          <td class="cyber-cell" data-label="Projecte">
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:8px;height:8px;border-radius:50%;background:{{ color }};flex-shrink:0;"></div>
              <div>
                <div class="table-project-name" style="font-size:0.82rem;font-weight:600;color:var(--s-text);">{{ project.name }}</div>
                <div style="font-size:0.62rem;color:var(--s-text-secondary);margin-top:1px;">{{ project.slug }}</div>
              </div>
            </div>
          </td>
          <td class="cyber-cell" data-label="Seccions" style="font-size:0.85rem;font-weight:600;color:var(--s-text);">
            {{ project.contentTypes|length }}
          </td>
          <td class="cyber-cell" data-label="Entrades" style="font-size:0.85rem;font-weight:600;color:var(--s-text);">
            {{ project.contentTypes|reduce((carry, ct) => carry + ct.entries|length, 0) }}
          </td>
          <td class="cyber-cell cyber-cell--status" data-label="Estat">
            {% if project.active %}
            <span class="cyber-status">
              <span class="cyber-status-dot cyber-status-dot--active"></span>
              <span class="cyber-status-text">Actiu</span>
            </span>
            {% else %}
            <span class="cyber-status">
              <span class="cyber-status-dot cyber-status-dot--inactive"></span>
              <span class="cyber-status-text cyber-status-text--inactive">Inactiu</span>
            </span>
            {% endif %}
          </td>
          <td class="cyber-cell" data-label="Accions" onclick="event.stopPropagation();">
            <div class="cyber-actions">
              <a href="{{ path('admin_switch_project', {id: project.id}) }}"
                 class="cyber-btn cyber-btn--projects" title="Obrir projecte">
                <i class="bi bi-arrow-right-circle"></i><span>Obrir</span>
              </a>
              <span class="cyber-actions-divider"></span>
              <form method="post" action="{{ path('admin_project_toggle_active', {id: project.id}) }}" style="display:inline" id="tact-project-{{ project.id }}">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle-active-' ~ project.id) }}">
                <button type="submit"
                        class="cyber-btn cyber-btn--icon {{ project.active ? 'cyber-btn--toggle-active' : 'cyber-btn--toggle-inactive' }}"
                        title="{{ project.active ? 'Desactivar' : 'Activar' }}">
                  <i class="bi {{ project.active ? 'bi-toggle2-on' : 'bi-toggle2-off' }}"></i>
                </button>
              </form>
              <a href="{{ path('admin_project_edit', {id: project.id}) }}"
                 class="cyber-btn cyber-btn--icon cyber-btn--edit" title="Editar">
                <i class="bi bi-pencil"></i>
              </a>
              {% if project.contentTypes|length == 0 %}
              <form method="post" action="{{ path('admin_project_delete', {id: project.id}) }}" style="display:inline" id="del-project-{{ project.id }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-project-' ~ project.id) }}">
                <button type="submit"
                        class="cyber-btn cyber-btn--icon cyber-btn--delete" title="Eliminar"
                        onclick="return confirm('Segur que vols eliminar el projecte «{{ project.name }}»?')">
                  <i class="bi bi-trash3"></i>
                </button>
              </form>
              {% else %}
              <button type="button" class="cyber-btn cyber-btn--icon cyber-btn--delete-disabled"
                      title="Elimina primer les seccions" disabled>
                <i class="bi bi-trash3"></i>
              </button>
              {% endif %}
            </div>
          </td>
        </tr>

{% if loop.last %}</tbody></table></div>{% endif %}
{% else %}
<div class="cyber-card" data-anim="cyber-card" style="padding:60px 24px;text-align:center;">
    <div class="cyber-empty-icon"><i class="bi bi-folder-plus"></i></div>
    <p class="cyber-empty-text">No hi ha projectes</p>
    <a href="{{ path('admin_project_new') }}" class="cyber-btn-primary" style="margin-top:16px;display:inline-flex;">
        <i class="bi bi-plus-lg"></i> <span>Crear projecte</span>
    </a>
</div>
{% endfor %}
{% endif %}

{% endblock %}
