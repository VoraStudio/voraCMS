{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ filterUser is defined and filterUser ? filterUser.name : 'Projectes' }}{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_project_new') }}" class="cyber-btn-primary" data-anim="cyber-btn">
    <i class="bi bi-plus-lg"></i> <span>Nou projecte</span>
</a>
{% endblock %}

{% block content %}

{# ─── User filter header ─── #}
{% if filterUser is defined and filterUser %}
<div class="cyber-section-header" data-anim="cyber-card" style="margin-bottom:24px;">
    <div class="cyber-section-header-left">
        <div class="cyber-section-icon">
            <i class="bi bi-person-fill"></i>
        </div>
        <div>
            <h2 class="cyber-section-title">{{ filterUser.name }}</h2>
            <p class="cyber-section-desc">Projectes i seccions</p>
        </div>
    </div>
    <div class="cyber-section-header-right">
        <div class="cyber-stat-mini">
            <span class="cyber-stat-mini-value">{{ mainProject ? mainProject.contentTypes|length : 0 }}</span>
            <span class="cyber-stat-mini-label">Seccions</span>
        </div>
        <div class="cyber-stat-mini">
            <span class="cyber-stat-mini-value">{{ otherProjects|length }}</span>
            <span class="cyber-stat-mini-label">Projectes</span>
        </div>
        <a href="{{ path('admin_projects') }}" class="cyber-btn-back" style="margin-left:8px;" title="Tornar a tots els projectes">
            <i class="bi bi-x-lg"></i> <span>Netejar</span>
        </a>
    </div>
</div>

{% if mainProject %}
    {# ─── Main project section header ─── #}
    {% set color = mainProject.color ?: '#06B6D4' %}
    <div class="cyber-card" data-anim="cyber-card" style="padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;gap:16px;">
        <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:8px;height:8px;border-radius:50%;background:{{ color }};flex-shrink:0;"></div>
            <div>
                <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;color:rgba(148,163,184,0.5);margin-bottom:1px;">Projecte principal</div>
                <div style="font-size:0.95rem;font-weight:600;color:var(--s-text);">{{ mainProject.name }}</div>
            </div>
        </div>
        <div style="display:flex;gap:8px;">
            <a href="{{ path('admin_project_edit', {id: mainProject.id}) }}" class="cyber-btn cyber-btn--icon cyber-btn--edit" title="Editar projecte">
                <i class="bi bi-pencil"></i>
            </a>
            <a href="{{ path('admin_switch_project', {id: mainProject.id}) }}" class="cyber-btn-primary" style="padding:8px 16px;font-size:0.7rem;">
                <i class="bi bi-arrow-right-circle"></i> <span>Obrir</span>
            </a>
        </div>
    </div>

    {# ─── Content type cards ─── #}
    <div class="row g-3" style="margin-bottom:32px;">
        {% for ct in mainProject.contentTypes %}
        {% set icon = ct.icon ?: 'bi-file-earmark' %}
        {% set entriesCount = ct.entries|length %}
        <div class="col-md-6 col-lg-4">
            <div class="cyber-card" data-anim="cyber-card" style="cursor:pointer;padding:24px 24px 20px;"
                 onclick="window.location='{{ path('admin_entry_by_type', {slug: ct.slug}) }}'">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;">
                    <div class="cyber-section-icon" style="width:44px;height:44px;border-radius:12px;font-size:1.1rem;margin:0;">
                        <i class="bi {{ icon }}"></i>
                    </div>
                    <span class="cyber-badge {{ entriesCount > 0 ? 'cyber-badge--mod' : '' }}" style="font-size:0.55rem;">
                        {{ entriesCount }} entrades
                    </span>
                </div>
                <h3 style="font-size:0.95rem;font-weight:700;margin:0 0 4px;color:var(--s-text);">{{ ct.name }}</h3>
                {% if ct.description %}
                <p style="font-size:0.75rem;color:var(--s-text-secondary);margin:0 0 12px;line-height:1.4;">{{ ct.description }}</p>
                {% endif %}
                <a href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}" class="cyber-btn cyber-btn--projects" style="font-size:0.6rem;padding:5px 12px;margin-top:4px;">
                    <i class="bi bi-eye"></i> <span>Veure entrades</span>
                </a>
            </div>
        </div>
        {% else %}
        <div class="col-12">
            <div class="cyber-card" data-anim="cyber-card" style="text-align:center;padding:40px 24px;">
                <div style="font-size:2.5rem;color:rgba(148,163,184,0.15);margin-bottom:12px;">
                    <i class="bi bi-layers"></i>
                </div>
                <p style="color:var(--s-text-secondary);font-size:0.85rem;margin:0 0 16px;">Aquest projecte no té seccions encara</p>
                <a href="{{ path('admin_switch_project', {id: mainProject.id}) }}" class="cyber-btn-primary" style="font-size:0.7rem;padding:8px 16px;">
                    <i class="bi bi-plus-lg"></i> <span>Crear secció</span>
                </a>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}

{# ─── Other projects ─── #}
{% if otherProjects|length > 0 %}
<h4 style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:rgba(148,163,184,0.4);margin:0 0 14px;">
    <i class="bi bi-folder2-open" style="margin-right:6px;"></i> Altres projectes
</h4>
<div class="row g-3">
    {% for project in otherProjects %}
    {% set color = project.color ?: '#4945FF' %}
    <div class="col-md-6 col-lg-4">
        <div class="cyber-card" data-anim="cyber-card"
             style="cursor:pointer;padding:20px 24px;border-left:3px solid {{ color }};"
             onclick="window.location='{{ path('admin_switch_project', {id: project.id}) }}'">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:38px;height:38px;border-radius:10px;background:rgba(148,163,184,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:{{ color }};font-size:1.1rem;">
                    <i class="bi bi-folder2-open"></i>
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:0.85rem;font-weight:600;color:var(--s-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ project.name }}</div>
                    <div style="font-size:0.65rem;color:var(--s-text-secondary);margin-top:2px;">
                        {{ project.contentTypes|length }} seccions · {{ project.contentTypes|reduce((carry, ct) => carry + ct.entries|length, 0) }} entrades
                    </div>
                </div>
                <i class="bi bi-chevron-right" style="color:rgba(148,163,184,0.3);font-size:0.8rem;"></i>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{% elseif projects is defined %}
{# ─── All projects view (no filter) ─── #}
<div class="row g-3">
    {% for project in projects %}
    {% set color = project.color ?: '#4945FF' %}
    <div class="col-md-6 col-lg-4">
        <div class="s-stat-card {{ project.active ? 'row-active' : 'row-inactive' }}"
             style="cursor:pointer;padding:28px 28px 24px;border-top:3px solid {{ color }};border-top-left-radius:24px;border-top-right-radius:24px;"
             onmouseover="this.style.borderTopColor='{{ color }}cc'"
             onmouseout="this.style.borderTopColor='{{ color }}'"
             onclick="window.location='{{ path('admin_switch_project', {id: project.id}) }}'">

            <div class="s-stat-card-icon" style="color:{{ color }}88;">
                <i class="bi bi-folder2-open"></i>
            </div>

            <h6 class="text-capitalize mb-2" style="display:flex;align-items:center;justify-content:center;gap:8px;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:{{ color }};flex-shrink:0;"></span>
                {{ project.name }}
            </h6>

            {% if project.description %}
            <p style="margin:0 0 12px;font-size:0.75rem;color:var(--s-text-secondary);line-height:1.4;text-align:center;">
                {{ project.description }}
            </p>
            {% endif %}

            <div class="s-stat-numbers mb-3" style="gap:32px;">
                <div>
                    <div class="s-stat-label">Seccions</div>
                    <div class="s-stat-value">{{ project.contentTypes|length }}</div>
                </div>
                <div>
                    <div class="s-stat-label">Entrades</div>
                    <div class="s-stat-value" style="color:rgba(96,165,250,0.90);">{{ project.contentTypes|reduce((carry, ct) => carry + ct.entries|length, 0) }}</div>
                </div>
            </div>

            <a href="{{ path('admin_switch_project', {id: project.id}) }}"
               class="s-stat-btn"
               onclick="event.stopPropagation();">
                <i class="bi bi-arrow-right-circle me-1"></i> Obrir projecte
            </a>

            <div style="display:flex;gap:8px;justify-content:center;margin-top:10px;">
                <a href="{{ path('admin_project_edit', {id: project.id}) }}"
                   class="s-stat-btn"
                   style="padding:8px 16px;font-size:0.75rem;width:auto;display:inline-flex;gap:6px;"
                   onclick="event.stopPropagation();">
                    <i class="bi bi-pencil"></i> Editar
                </a>
                <form method="post" action="{{ path('admin_project_toggle_active', {id: project.id}) }}" style="display:inline" id="tact-project-{{ project.id }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('toggle-active-' ~ project.id) }}">
                    <button type="submit"
                            class="s-stat-btn"
                            style="padding:8px 16px;font-size:0.75rem;width:auto;display:inline-flex;gap:6px;"
                            onclick="event.stopPropagation();">
                        {{ project.active ? 'Desactivar' : 'Activar' }}
                    </button>
                </form>
                <button type="button"
                        class="s-stat-btn"
                        style="padding:8px 16px;font-size:0.75rem;width:auto;display:inline-flex;gap:6px;color:rgba(239,83,80,0.70);border-color:rgba(239,83,80,0.15);"
                        onmouseover="this.style.borderColor='rgba(239,83,80,0.40)';this.style.color='rgba(239,83,80,0.90)';"
                        onmouseout="this.style.borderColor='rgba(239,83,80,0.15)';this.style.color='rgba(239,83,80,0.70)';"
                        onclick="event.stopPropagation();document.getElementById('delete-{{ project.id }}').submit();"
                        {% if project.contentTypes|length > 0 %}disabled title="Elimina primer les seccions"{% endif %}>
                    <i class="bi bi-trash"></i> Eliminar
                </button>
                <form id="delete-{{ project.id }}" action="{{ path('admin_project_delete', {id: project.id}) }}" method="post" style="display:none;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-project-' ~ project.id) }}">
                </form>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12">
        <div class="s-stat-card" style="text-align:center;padding:60px 24px;">
            <div class="s-stat-card-icon" style="font-size:3.5rem;color:rgba(255,255,255,0.15);margin-bottom:16px;">
                <i class="bi bi-folder-plus"></i>
            </div>
            <h6 style="color:var(--s-text);margin-bottom:8px;">No hi ha projectes</h6>
            <p style="color:var(--s-text-secondary);font-size:0.85rem;margin-bottom:24px;">
                Crea el teu primer projecte per començar a gestionar continguts.
            </p>
            <a href="{{ path('admin_project_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> <span>Crear projecte</span>
            </a>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{% endblock %}
