{% extends 'admin/layout.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block content %}
{% set cardIcons = ['bi-file-text', 'bi-calendar-event', 'bi-person', 'bi-image', 'bi-link', 'bi-star', 'bi-geo-alt', 'bi-chat-dots'] %}
<div class="s-dashboard">

{##}
{## ─── ADMIN DASHBOARD — Global, tots els usuaris ─── #}
{##}
{% if isAdmin is defined and isAdmin %}

    {# ─── Mètriques globals ─── #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-people me-1 s-stat-label-icon"></i> Usuaris
                </div>
                <div class="s-stat-value">{{ metrics.totalUsuaris }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-folder me-1 s-stat-label-icon"></i> Projectes
                </div>
                <div class="s-stat-value">{{ metrics.totalProyectos }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-check-circle me-1 s-stat-label-icon"></i> Publicacions
                </div>
                <div class="s-stat-value s-stat-value--success">{{ metrics.totalPublicaciones }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-eye me-1 s-stat-label-icon"></i> Visites avui
                </div>
                <div class="s-stat-value s-stat-value--accent">{{ metrics.totalVisites }}</div>
            </div>
        </div>
    </div>

    {# ─── Últims registres: Clients · Projectes · Seccions ─── #}
    <div class="row g-3 mb-4">
        {# ─── Últims clients ─── #}
        <div class="col-md-4">
            <div class="cyber-card cyber-card--list" data-anim="cyber-card">
                <div class="cyber-card-header">
                    <h6 class="cyber-card-header__title">
                        <i class="bi bi-people"></i> Últims clients
                    </h6>
                </div>
                <div class="cyber-card-list__body">
                    {% for u in latestUsers %}
                    <a href="{{ path('admin_user_edit', {id: u.id}) }}" class="cyber-list-item">
                        <div class="cyber-avatar cyber-list-item__icon--avatar">{{ u.name|first|upper }}</div>
                        <div class="cyber-list-item__body">
                            <div class="cyber-list-item__title">{{ u.name }}</div>
                            <div class="cyber-list-item__subtitle">{{ u.company ?: u.email }}</div>
                        </div>
                        <i class="bi bi-chevron-right cyber-list-item__arrow"></i>
                    </a>
                    {% else %}
                    <div class="cyber-list-empty">No hi ha clients</div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# ─── Últims projectes ─── #}
        <div class="col-md-4">
            <div class="cyber-card cyber-card--list" data-anim="cyber-card">
                <div class="cyber-card-header">
                    <h6 class="cyber-card-header__title">
                        <i class="bi bi-folder2-open"></i> Últims projectes
                    </h6>
                </div>
                <div class="cyber-card-list__body">
                    {% for p in latestProjects %}
                    {% set color = p.color ?: '#4945FF' %}
                    <a href="{{ path('admin_switch_project', {id: p.id}) }}" class="cyber-list-item">
                        <div class="cyber-list-item__icon cyber-list-item__icon--dynamic" style="--icon-clr:{{ color }};">
                            <i class="bi bi-folder2-open"></i>
                        </div>
                        <div class="cyber-list-item__body">
                            <div class="cyber-list-item__title">{{ p.name }}</div>
                            <div class="cyber-list-item__subtitle">
                                {% if p.user %}{{ p.user.name }} · {% endif %}{{ p.contentTypes|length }} seccions
                            </div>
                        </div>
                        <i class="bi bi-chevron-right cyber-list-item__arrow"></i>
                    </a>
                    {% else %}
                    <div class="cyber-list-empty">No hi ha projectes</div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# ─── Últimes seccions ─── #}
        <div class="col-md-4">
            <div class="cyber-card cyber-card--list" data-anim="cyber-card">
                <div class="cyber-card-header">
                    <h6 class="cyber-card-header__title">
                        <i class="bi bi-grid-1x2"></i> Últimes seccions
                    </h6>
                </div>
                <div class="cyber-card-list__body">
                    {% for ct in latestContentTypes %}
                    {% set icon = 'bi-file-earmark' %}
                    <a href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}" class="cyber-list-item">
                        <div class="cyber-list-item__icon cyber-list-item__icon--content-type">
                            <i class="bi {{ icon }}"></i>
                        </div>
                        <div class="cyber-list-item__body">
                            <div class="cyber-list-item__title">{{ ct.name }}</div>
                            <div class="cyber-list-item__subtitle">
                                {{ ct.project ? ct.project.name : 'Sense projecte' }} · {{ ct.entries|length }} entrades
                            </div>
                        </div>
                        <i class="bi bi-chevron-right cyber-list-item__arrow"></i>
                    </a>
                    {% else %}
                    <div class="cyber-list-empty">No hi ha seccions</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

{##}
{## ─── NON-ADMIN DASHBOARD — Scoped a l'usuari ─── #}
{##}
{% else %}

    {# ─── Mètriques agregades ─── #}
    {% if metrics is defined and metrics %}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-file-text me-1 s-stat-label-icon"></i> Entrades
                </div>
                <div class="s-stat-value">{{ metrics.totalEntries }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-check-circle me-1 s-stat-label-icon"></i> Publicacions
                </div>
                <div class="s-stat-value s-stat-value--success">{{ metrics.totalPublished }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-images me-1 s-stat-label-icon"></i> Fitxers
                </div>
                <div class="s-stat-value">{{ metrics.totalMedia }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-folder me-1 s-stat-label-icon"></i> Projectes
                </div>
                <div class="s-stat-value">{{ metrics.totalProjects }}</div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ─── Content Type Stats (només si hi ha projecte actiu) ─── #}
    {% if projectToShow is not null %}
        {% if stats is empty %}
        <div class="text-center py-5 cyber-list-empty">
            <i class="bi bi-folder-plus display-3 cyber-empty-icon--lg"></i>
            <p class="mt-3">Aquest projecte no té seccions encara.</p>
            <a href="{{ path('admin_content_type_new') }}" class="btn btn-primary"><span>Crear primera secció</span></a>
        </div>
        {% else %}
        <div class="project-section-header">
            <h6 class="project-section-title">
                <i class="bi bi-grid-1x2 me-2"></i>{{ projectToShow.name }}
            </h6>
        </div>
        <div class="row g-3">
            {% for stat in stats %}
            {% set icon = cardIcons[loop.index0 % cardIcons|length] %}
            <div class="col-md-4">
                <div class="s-stat-card" data-anim="card">
                    <div class="s-stat-card-icon">
                        <i class="bi {{ icon }}"></i>
                    </div>
                    <h6 class="text-capitalize mb-2">{{ stat.type.name }}</h6>
                    <div class="s-stat-numbers s-stat-numbers--compact mb-3">
                        <div>
                            <div class="s-stat-label">Entrades</div>
                            <div class="s-stat-value">{{ stat.total }}</div>
                        </div>
                        <div>
                            <div class="s-stat-label">Publicacions</div>
                            <div class="s-stat-value s-stat-value--success">{{ stat.published }}</div>
                        </div>
                    </div>
                    <a href="{{ path('admin_entry_by_type', {slug: stat.type.slug}) }}" class="s-stat-btn">
                        <i class="bi bi-arrow-right-circle me-1"></i> Gestionar entrades
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    {% endif %}

{% endif %}

</div>
{% endblock %}
