{% extends 'admin/layout.html.twig' %}

{% block page_title %}
    {% if currentClient %}Dashboard · {{ currentClient.name }}{% else %}Dashboard{% endif %}
{% endblock %}

{% block content %}
{% set cardIcons = ['bi-file-text', 'bi-calendar-event', 'bi-person', 'bi-image', 'bi-link', 'bi-star', 'bi-geo-alt', 'bi-chat-dots'] %}
<div class="s-dashboard">

{# ─── Client Context Header ─── #}
{% if currentClient %}
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 28px; position: relative; z-index: 1;">
        {% if currentClient.logo %}
            <img src="{{ currentClient.logo }}" alt="{{ currentClient.name }}" style="width: 40px; height: 40px; object-fit: cover; border-radius: 12px; border: 2px solid rgba(255,255,255,0.10);">
        {% else %}
            <div style="width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, rgba(73,69,255,0.35), rgba(73,69,255,0.12)); display: flex; align-items: center; justify-content: center; font-size: 1rem; font-weight: 700; color: rgba(73,69,255,0.75); flex-shrink: 0;">
                {{ currentClient.name|first|upper }}
            </div>
        {% endif %}
        <div>
            <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.35);">Gestionant</div>
            <div style="font-size: 1.1rem; font-weight: 650; color: rgba(255,255,255,0.85); letter-spacing: -0.02em;">{{ currentClient.name }}</div>
        </div>
    </div>
{% endif %}

{# ─── Super Admin Overview ─── #}
{% if is_granted('ROLE_SUPER_ADMIN') and clients is not empty %}
    <div style="margin-bottom: 32px; position: relative; z-index: 1;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
            <h6 style="color: rgba(255,255,255,0.60); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">
                <i class="bi bi-buildings me-2" style="color: rgba(73,69,255,0.60);"></i>Tots els clients
            </h6>
            <a href="{{ path('admin_client_index') }}" class="btn btn-outline-primary btn-sm" style="font-size:0.75rem;padding:6px 14px;min-height:32px;">
                Gestionar <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row g-3">
            {% for client in clients %}
            <div class="col-md-3">
                <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; padding: 18px; transition: all 300ms ease; cursor: default;"
                     onmouseover="this.style.borderColor='rgba(73,69,255,0.25)';this.style.background='rgba(73,69,255,0.04)';"
                     onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.background='rgba(255,255,255,0.02)';">
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                        {% if client.logo %}
                            <img src="{{ client.logo }}" alt="{{ client.name }}" style="width:32px;height:32px;object-fit:cover;border-radius:8px;">
                        {% else %}
                            <div style="width:32px;height:32px;border-radius:8px;background: linear-gradient(135deg, rgba(73,69,255,0.30), rgba(73,69,255,0.08)); display:flex;align-items:center;justify-content:center; font-weight:700; font-size:0.75rem; color: rgba(73,69,255,0.70);">
                                {{ client.name|first|upper }}
                            </div>
                        {% endif %}
                        <div>
                            <div style="font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.80);">{{ client.name }}</div>
                            <code style="font-size:0.65rem;">{{ client.slug }}</code>
                        </div>
                    </div>
                    <div style="display: flex; gap: 16px; font-size: 0.7rem; color: rgba(255,255,255,0.40);">
                        <span><i class="bi bi-layers me-1" style="font-size:0.6rem;"></i> {{ client.contentTypes|length }}</span>
                        <span><i class="bi bi-file-text me-1" style="font-size:0.6rem;"></i> {{ client.entries|length }}</span>
                        <span><i class="bi bi-people me-1" style="font-size:0.6rem;"></i> {{ client.users|length }}</span>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div style="margin-bottom: 24px; position: relative; z-index: 1;">
        <h6 style="color: rgba(255,255,255,0.60); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 4px;">
            <i class="bi bi-grid-1x2 me-2" style="color: rgba(73,69,255,0.60);"></i>Tipus de contingut globals
        </h6>
        <span style="font-size:0.7rem;color:rgba(255,255,255,0.30);">Visió agregada de tots els clients</span>
    </div>
{% endif %}

{# ─── Content Type Stats ─── #}
{% if stats is empty %}
<div class="text-center py-5" style="color:rgba(255,255,255,0.5);position:relative;z-index:1;">
    <i class="bi bi-folder-plus display-3" style="color:rgba(255,255,255,0.15);"></i>
    <p class="mt-3">No hi ha tipus de contingut encara.</p>
    <a href="{{ path('admin_content_type_new') }}" class="btn btn-primary">Crear primer tipus</a>
</div>
{% else %}
<div class="row g-3" style="position:relative;z-index:1;">
    {% for stat in stats %}
    {% set icon = cardIcons[loop.index0 % cardIcons|length] %}
    <div class="col-md-4">
        <div class="s-stat-card">
            <div class="s-stat-card-icon">
                <i class="bi {{ icon }}"></i>
            </div>
            <h6 class="text-capitalize mb-2">{{ stat.type.name }}</h6>
            <span class="s-stat-badge mb-3">{{ stat.type.fields|length }} camps</span>
            <div class="s-stat-numbers mb-3">
                <div>
                    <div class="s-stat-label">Total</div>
                    <div class="s-stat-value">{{ stat.total }}</div>
                </div>
                <div>
                    <div class="s-stat-label">Publicades</div>
                    <div class="s-stat-value s-stat-value--success">{{ stat.published }}</div>
                </div>
            </div>
            <a href="{{ path('admin_entry_by_type', {slug: stat.type.slug}) }}" class="s-stat-btn">
                <i class="bi bi-arrow-right-circle me-1"></i> Gestionar entrades
            </a>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

</div>
{% endblock %}
