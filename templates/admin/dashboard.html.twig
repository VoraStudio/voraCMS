{% extends 'admin/layout.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block topbar_actions %}{% endblock %}

{% block content %}
<div class="cyber-form-card">
{% set cardIcons = ['bi-file-text', 'bi-calendar-event', 'bi-person', 'bi-image', 'bi-link', 'bi-star', 'bi-geo-alt', 'bi-chat-dots'] %}
<div class="s-dashboard">

{##}
{## ─── ADMIN DASHBOARD — Global, tots els usuaris ─── #}
{##}
{% if isAdmin is defined and isAdmin %}

    {# ─── Mètriques globals ─── #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-people me-1 s-stat-label-icon"></i> Usuaris
                </div>
                <div class="s-stat-value">{{ metrics.totalUsuaris }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-folder me-1 s-stat-label-icon"></i> Projectes
                </div>
                <div class="s-stat-value">{{ metrics.totalProyectos }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-check-circle me-1 s-stat-label-icon"></i> Publicacions
                </div>
                <div class="s-stat-value s-stat-value--success">{{ metrics.totalPublicaciones }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-eye me-1 s-stat-label-icon"></i> Visites avui
                </div>
                <div class="s-stat-value s-stat-value--accent">{{ metrics.totalVisites }}</div>
            </div>
        </div>
    </div>

    {# ─── Mètriques API —────────────────────────────────── #}
    {% if chartData is defined %}
    <div class="row g-3 mb-4">
        {# ── Card: Peticions API avui ── #}
        <div class="col-md-4">
            <div class="s-stat-card" data-anim="chart-card">
                <div class="s-stat-card-icon">
                    <i class="bi bi-arrow-left-right"></i>
                </div>
                <h6>Peticions API</h6>
                <div class="s-stat-value" style="font-size:2.4rem;">{{ chartData.apiToday }}</div>
                <div class="mt-3">
                    <canvas id="chartApiStatus" height="120"></canvas>
                </div>
                <div class="d-flex justify-content-center gap-3 mt-2" style="font-size:0.65rem;color:rgba(255,255,255,0.5);">
                    <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#10b981;margin-right:4px;"></span>{{ chartData.api2xx }} OK</span>
                    <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#f59e0b;margin-right:4px;"></span>{{ chartData.api4xx }}</span>
                    <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ef4444;margin-right:4px;"></span>{{ chartData.api5xx }}</span>
                </div>
            </div>
        </div>

        {# ── Card: Token Grants ── #}
        <div class="col-md-4">
            <div class="s-stat-card" data-anim="chart-card">
                <div class="s-stat-card-icon">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h6>Tokens</h6>
                <div class="d-flex justify-content-center gap-4 mt-2">
                    <div class="text-center">
                        <div style="font-size:1.8rem;font-weight:700;color:rgba(16,185,129,0.9);">{{ chartData.tokenGrants }}</div>
                        <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.06em;color:rgba(255,255,255,0.4);">Concedits</div>
                    </div>
                    <div class="text-center">
                        <div style="font-size:1.8rem;font-weight:700;color:rgba(239,68,68,0.8);">{{ chartData.tokenDenials }}</div>
                        <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.06em;color:rgba(255,255,255,0.4);">Denegats</div>
                    </div>
                </div>
                <div class="mt-2">
                    <canvas id="chartTokens" height="100"></canvas>
                </div>
            </div>
        </div>

        {# ── Card: Temps de resposta ── #}
        <div class="col-md-4">
            <div class="s-stat-card" data-anim="chart-card">
                <div class="s-stat-card-icon">
                    <i class="bi bi-speedometer2"></i>
                </div>
                <h6>Temps de resposta</h6>
                <div class="s-stat-value s-stat-value--accent" style="font-size:2.4rem;">
                    {{ chartData.avgResponse }}
                    <span style="font-size:0.9rem;font-weight:400;color:rgba(255,255,255,0.4);">ms</span>
                </div>
                <div class="mt-2">
                    <canvas id="chartResponse" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

    {# ─── Secció: Tràfic i Origins ─── #}
    <div class="row g-3 mb-4">
        {# ── Gràfic: Visites 7 dies ── #}
        <div class="col-md-8">
            <div class="s-stat-card" data-anim="chart-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 style="margin:0;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.5);">
                        <i class="bi bi-graph-up me-2" style="color:rgba(249,115,22,0.6);"></i>Visites (7 dies)
                    </h6>
                </div>
                <canvas id="chartVisits" height="180"></canvas>
            </div>
        </div>

        {# ── Top Origins ── #}
        <div class="col-md-4">
            <div class="s-stat-card" data-anim="chart-card">
                <h6 style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.5);margin-bottom:16px;">
                    <i class="bi bi-globe me-2" style="color:rgba(249,115,22,0.6);"></i>Top dominis
                </h6>
                <div id="topOriginsList">
                    {% if chartData.topOrigins is empty %}
                    <div style="text-align:center;padding:20px;color:rgba(255,255,255,0.25);font-size:0.75rem;">
                        <i class="bi bi-inbox" style="font-size:1.5rem;display:block;margin-bottom:8px;"></i>
                        Sense dades avui
                    </div>
                    {% else %}
                    {% set maxOrigin = chartData.topOrigins|first|default({'total':1}) %}
                    {% for item in chartData.topOrigins %}
                    {% set pct = (item.total / maxOrigin.total * 100)|round %}
                    <div style="margin-bottom:10px;">
                        <div class="d-flex justify-content-between" style="font-size:0.7rem;color:rgba(255,255,255,0.6);margin-bottom:3px;">
                            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:180px;">{{ item.origin }}</span>
                            <span style="font-weight:600;color:rgba(255,255,255,0.8);">{{ item.total }}</span>
                        </div>
                        <div style="height:4px;background:rgba(255,255,255,0.06);border-radius:4px;overflow:hidden;">
                            <div style="width:{{ pct }}%;height:100%;background:linear-gradient(90deg,rgba(249,115,22,0.7),rgba(250,204,21,0.6));border-radius:4px;transition:width 0.8s ease;"></div>
                        </div>
                    </div>
                    {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ─── Últims registres: Clients · Projectes · Seccions ─── #}
    <div class="row g-3 mb-4">
        {# ─── Últims clients ─── #}
        <div class="col-md-4">
            <div class="cyber-card cyber-card--list" data-anim="cyber-card">
                <div class="cyber-card-header">
                    <h6 class="cyber-card-header__title">
                        <i class="bi bi-people"></i> Últims clients
                    </h6>
                </div>
                <div class="cyber-card-list__body">
                    {% for u in latestUsers %}
                    <a href="{{ path('admin_user_edit', {id: u.id}) }}" class="cyber-list-item">
                        <div class="cyber-avatar cyber-list-item__icon--avatar">{{ u.name|first|upper }}</div>
                        <div class="cyber-list-item__body">
                            <div class="cyber-list-item__title">{{ u.name }}</div>
                            <div class="cyber-list-item__subtitle">{{ u.company ?: u.email }}</div>
                        </div>
                        <i class="bi bi-chevron-right cyber-list-item__arrow"></i>
                    </a>
                    {% else %}
                    <div class="cyber-list-empty">No hi ha clients</div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# ─── Últims projectes ─── #}
        <div class="col-md-4">
            <div class="cyber-card cyber-card--list" data-anim="cyber-card">
                <div class="cyber-card-header">
                    <h6 class="cyber-card-header__title">
                        <i class="bi bi-folder2-open"></i> Últims projectes
                    </h6>
                </div>
                <div class="cyber-card-list__body">
                    {% for p in latestProjects %}
                    {% set color = p.color ?: '#4945FF' %}
                    <a href="{{ path('admin_switch_project', {id: p.id}) }}" class="cyber-list-item">
                        <div class="cyber-list-item__icon cyber-list-item__icon--dynamic" style="--icon-clr:{{ color }};">
                            <i class="bi bi-folder2-open"></i>
                        </div>
                        <div class="cyber-list-item__body">
                            <div class="cyber-list-item__title">{{ p.name }}</div>
                            <div class="cyber-list-item__subtitle">
                                {% if p.user %}{{ p.user.name }} · {% endif %}{{ p.contentTypes|length }} seccions
                            </div>
                        </div>
                        <i class="bi bi-chevron-right cyber-list-item__arrow"></i>
                    </a>
                    {% else %}
                    <div class="cyber-list-empty">No hi ha projectes</div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# ─── Últimes seccions ─── #}
        <div class="col-md-4">
            <div class="cyber-card cyber-card--list" data-anim="cyber-card">
                <div class="cyber-card-header">
                    <h6 class="cyber-card-header__title">
                        <i class="bi bi-grid-1x2"></i> Últimes seccions
                    </h6>
                </div>
                <div class="cyber-card-list__body">
                    {% for ct in latestContentTypes %}
                    {% set icon = 'bi-file-earmark' %}
                    <a href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}" class="cyber-list-item">
                        <div class="cyber-list-item__icon cyber-list-item__icon--content-type">
                            <i class="bi {{ icon }}"></i>
                        </div>
                        <div class="cyber-list-item__body">
                            <div class="cyber-list-item__title">{{ ct.name }}</div>
                            <div class="cyber-list-item__subtitle">
                                {{ ct.project ? ct.project.name : 'Sense projecte' }} · {{ ct.entries|length }} entrades
                            </div>
                        </div>
                        <i class="bi bi-chevron-right cyber-list-item__arrow"></i>
                    </a>
                    {% else %}
                    <div class="cyber-list-empty">No hi ha seccions</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

{##}
{## ─── NON-ADMIN DASHBOARD — Scoped a l'usuari ─── #}
{##}
{% else %}

    {# ─── Mètriques agregades ─── #}
    {% if metrics is defined and metrics %}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-file-text me-1 s-stat-label-icon"></i> Entrades
                </div>
                <div class="s-stat-value">{{ metrics.totalEntries }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-check-circle me-1 s-stat-label-icon"></i> Publicacions
                </div>
                <div class="s-stat-value s-stat-value--success">{{ metrics.totalPublished }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-images me-1 s-stat-label-icon"></i> Fitxers
                </div>
                <div class="s-stat-value">{{ metrics.totalMedia }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="s-stat-card s-stat-card--metric" data-anim="metric">
                <div class="s-stat-label s-stat-label--metric">
                    <i class="bi bi-folder me-1 s-stat-label-icon"></i> Projectes
                </div>
                <div class="s-stat-value">{{ metrics.totalProjects }}</div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ─── Els teus projectes ─── #}
    <div class="project-section-header mb-3">
        <h6 class="project-section-title">
            <i class="bi bi-folder2-open me-2"></i>Els teus projectes
        </h6>
    </div>
    <div class="row g-3">
        {% for pd in projectsData %}
        {% set p = pd.project %}
        {% set color = p.color ?: '#06b6d4' %}
        {% set isActive = (activeProjectId is defined and p.id == activeProjectId) %}
        <div class="col-12">
            <div class="cyber-project-card-row {% if isActive %}cyber-project-card-row--active{% endif %}">
                
                {# Izquierda: Icono y Nombre del Proyecto #}
                <div class="cyber-project-info">
                    <div class="cyber-project-icon" style="--proj-color: {{ color }};">
                        <i class="bi bi-folder2-open"></i>
                    </div>
                    <div>
                        <div class="cyber-project-title">{{ p.name }}</div>
                        <div class="cyber-project-subtitle">ID {{ p.id }}</div>
                    </div>
                </div>

                {# Centro: Métricas horizontales #}
                <div class="cyber-project-metrics-row">
                    <div class="cyber-project-metric-col">
                        <span class="cyber-project-metric-lbl">
                            <i class="bi bi-layers-half me-1"></i> Seccions
                        </span>
                        <span class="cyber-project-metric-num">{{ pd.totalSections }}</span>
                    </div>
                    <div class="cyber-project-metric-divider"></div>
                    <div class="cyber-project-metric-col">
                        <span class="cyber-project-metric-lbl">
                            <i class="bi bi-collection-play me-1"></i> Entrades
                        </span>
                        <span class="cyber-project-metric-num">{{ pd.totalEntries }}</span>
                    </div>
                    <div class="cyber-project-metric-divider"></div>
                    <div class="cyber-project-metric-col">
                        <span class="cyber-project-metric-lbl">
                            <i class="bi bi-broadcast me-1"></i> Publicats
                        </span>
                        <span class="cyber-project-metric-num text-success-neon">{{ pd.totalPublished }}</span>
                    </div>
                </div>

                {# Derecha: Badge de estado y Botón de acción #}
                <div class="cyber-project-actions-row">
                    {% if isActive %}
                    <span class="cyber-project-badge-neon me-3">Actiu</span>
                    {% endif %}
                    <a href="{{ path('admin_switch_project', {id: p.id, _redirect: path('admin_project_show', {id: p.id})}) }}" class="cyber-btn cyber-btn--projects cyber-btn--compact-row">
                        <span>Gestionar</span> <i class="bi bi-chevron-right ms-2"></i>
                    </a>
                </div>

            </div>
        </div>
        {% endfor %}
    </div>

{% endif %}

</div>
</div>
{% include 'admin/components/_help_faq.html.twig' with { form_context: 'dashboard' } %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  /* ── Tema fosc Chart.js ── */
  Chart.defaults.color = 'rgba(255,255,255,0.55)';
  Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';
  Chart.defaults.font.family = "'Inter','Segoe UI',sans-serif";

  {% if chartData is defined %}

  /* ── 1. API Status (Doughnut) ── */
  var ctx1 = document.getElementById('chartApiStatus');
  if (ctx1) {
    new Chart(ctx1, {
      type: 'doughnut',
      data: {
        labels: ['2xx OK', '4xx', '5xx'],
        datasets: [{
          data: [{{ chartData.api2xx }}, {{ chartData.api4xx }}, {{ chartData.api5xx }}],
          backgroundColor: ['rgba(16,185,129,0.75)', 'rgba(245,158,11,0.75)', 'rgba(239,68,68,0.75)'],
          borderWidth: 0,
          hoverOffset: 6,
        }]
      },
      options: {
        responsive: true,
        cutout: '70%',
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(15,23,42,0.95)',
            titleColor: '#fff',
            bodyColor: 'rgba(255,255,255,0.7)',
            borderColor: 'rgba(255,255,255,0.08)',
            borderWidth: 1,
            cornerRadius: 8,
          }
        },
        animation: {
          animateRotate: true,
          duration: 1200,
          easing: 'easeOutQuart',
        }
      }
    });
  }

  /* ── 2. Token Grants vs Denials (Doughnut) ── */
  var ctx2 = document.getElementById('chartTokens');
  if (ctx2) {
    new Chart(ctx2, {
      type: 'doughnut',
      data: {
        labels: ['Concedits', 'Denegats'],
        datasets: [{
          data: [{{ chartData.tokenGrants }}, {{ chartData.tokenDenials }}],
          backgroundColor: ['rgba(16,185,129,0.75)', 'rgba(239,68,68,0.75)'],
          borderWidth: 0,
          hoverOffset: 6,
        }]
      },
      options: {
        responsive: true,
        cutout: '75%',
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(15,23,42,0.95)',
            titleColor: '#fff',
            bodyColor: 'rgba(255,255,255,0.7)',
            borderColor: 'rgba(255,255,255,0.08)',
            borderWidth: 1,
            cornerRadius: 8,
          }
        },
        animation: {
          animateRotate: true,
          duration: 1000,
          easing: 'easeOutQuart',
        }
      }
    });
  }

  /* ── 3. Response Time Gauge (mini bar) ── */
  var ctx3 = document.getElementById('chartResponse');
  if (ctx3) {
    new Chart(ctx3, {
      type: 'bar',
      data: {
        labels: ['Avui'],
        datasets: [{
          data: [{{ chartData.avgResponse }}],
          backgroundColor: ['rgba(249,115,22,0.6)'],
          borderRadius: 6,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true,
        indexAxis: 'y',
        scales: {
          x: {
            display: false,
            beginAtZero: true,
            max: {{ chartData.avgResponse > 0 ? (chartData.avgResponse * 2) : 100 }},
            grid: { display: false },
          },
          y: {
            display: false,
            grid: { display: false },
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(15,23,42,0.95)',
            titleColor: '#fff',
            bodyColor: 'rgba(255,255,255,0.7)',
            borderColor: 'rgba(255,255,255,0.08)',
            borderWidth: 1,
            cornerRadius: 8,
            callbacks: {
              label: function(ctx) { return ctx.parsed.x + ' ms'; }
            }
          }
        },
        animation: {
          duration: 1500,
          easing: 'easeOutQuart',
        }
      }
    });
  }

  /* ── 4. Visites 7 dies (Line) ── */
  var ctx4 = document.getElementById('chartVisits');
  if (ctx4) {
    var days = [{% for v in chartData.visitsWeek %}'{{ v.date|date('d/m') }}'{{ not loop.last ? ',' }}{% endfor %}];
    var values = [{% for v in chartData.visitsWeek %}{{ v.total }}{{ not loop.last ? ',' }}{% endfor %}];

    new Chart(ctx4, {
      type: 'line',
      data: {
        labels: days,
        datasets: [{
          data: values,
          borderColor: 'rgba(249,115,22,0.8)',
          backgroundColor: function(ctx) {
            var g = ctx.chart.ctx.createLinearGradient(0, 0, 0, 180);
            g.addColorStop(0, 'rgba(249,115,22,0.25)');
            g.addColorStop(1, 'rgba(249,115,22,0.01)');
            return g;
          },
          fill: true,
          tension: 0.4,
          pointBackgroundColor: 'rgba(249,115,22,0.9)',
          pointBorderColor: 'rgba(15,23,42,0.8)',
          pointBorderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 7,
          borderWidth: 2,
        }]
      },
      options: {
        responsive: true,
        scales: {
          x: {
            grid: { display: false },
            ticks: { font: { size: 10 }, color: 'rgba(255,255,255,0.35)' },
          },
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(255,255,255,0.04)' },
            ticks: { font: { size: 10 }, color: 'rgba(255,255,255,0.35)', stepSize: 1 },
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(15,23,42,0.95)',
            titleColor: '#fff',
            bodyColor: 'rgba(255,255,255,0.7)',
            borderColor: 'rgba(255,255,255,0.08)',
            borderWidth: 1,
            cornerRadius: 8,
          }
        },
        animation: {
          duration: 1400,
          easing: 'easeOutQuart',
        },
        interaction: {
          intersect: false,
          mode: 'index',
        },
      }
    });
  }
  {% endif %}

  /* ── 5. GSAP microinteraccions per les cards noves ── */
  if (typeof gsap !== 'undefined') {
    gsap.utils.toArray('[data-anim="chart-card"]').forEach(function(el, i) {
      gsap.from(el, {
        y: 30,
        opacity: 0,
        duration: 0.7,
        delay: 0.1 + i * 0.08,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 92%',
        },
      });
    });

    /* Top origins bars: animació progressiva */
    document.querySelectorAll('#topOriginsList > div > div:last-child > div').forEach(function(bar, i) {
      var w = bar.style.width;
      bar.style.width = '0%';
      gsap.to(bar, {
        width: w,
        duration: 0.8,
        delay: 0.3 + i * 0.1,
        ease: 'power2.out',
      });
    });
  }
});
</script>
{% endblock %}
