{% extends 'admin/layout.html.twig' %}

{% set breadcrumbs = [
    {label: 'Dashboard', url: path('admin_dashboard')},
    {label: 'Tipus per defecte'}
] %}
{% set page_desc = 'Plantilles base disponibles. Les que tenen "Auto clonar" actiu es clonen automàticament en crear un projecte nou' %}

{% block page_title %}Tipus per defecte{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_base_content_new') }}" class="cyber-btn cyber-btn--projects" data-anim="cyber-btn">
    <i class="bi bi-plus-lg"></i> <span>Nova plantilla</span>
</a>
{% endblock %}

{% block content %}
{% include 'admin/project/_project_header_bar.html.twig' %}
<div class="d2-body">


<div class="cyber-tabs mb-4">
    <a href="{{ path('admin_content_type_index') }}" class="cyber-tab">
        <i class="bi bi-layers-fill"></i> Tipus del projecte
    </a>
    <a href="{{ path('admin_base_content_index') }}" class="cyber-tab cyber-tab--active">
        <i class="bi bi-window-stack"></i> Plantilles globals
    </a>
</div>

<div class="cyber-card cyber-card--table cyber-card--flush" data-anim="cyber-card">
    <table class="cyber-table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Tipo</th>
                <th>Camps</th>
                <th>Auto clonar</th>
                <th>Actiu</th>
                <th>Accions</th>
            </tr>
        </thead>
        <tbody>
        {% for ct in templates %}
            <tr class="cyber-row {{ ct.active ? 'row-active' : 'row-inactive' }}">
                <td class="cyber-cell text-capitalize fw-semibold">{{ ct.name }}</td>
                <td class="cyber-cell">
                    <span class="cyber-badge cyber-badge--field">{{ ct.slug|upper }}</span>
                </td>
                <td class="cyber-cell cyber-cell--numeric">{{ ct.fields|length }}</td>
                <td class="cyber-cell cyber-cell--status">
                    {% include 'admin/components/_status.html.twig' with {active: ct.autoClone} %}
                </td>
                <td class="cyber-cell cyber-cell--status">
                    {% include 'admin/components/_status.html.twig' with {active: ct.active} %}
                </td>
                <td class="cyber-cell" data-label="Accions">
                    <div class="cyber-actions">
                        <a href="{{ path('admin_base_content_show', {id: ct.id}) }}"
                           class="cyber-btn cyber-btn--projects" title="Veure">
                            <i class="bi bi-eye"></i> <span>Veure</span>
                        </a>

                        <span class="cyber-actions-divider"></span>

                        <a href="{{ path('admin_base_content_edit', {id: ct.id}) }}"
                           class="cyber-btn cyber-btn--icon cyber-btn--edit" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <form method="post" action="{{ path('admin_base_content_delete', {id: ct.id}) }}" class="cyber-form--inline" id="del-base-content-{{ ct.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ct.id) }}">
                            <button type="button" class="cyber-btn cyber-btn--icon cyber-btn--delete" title="Eliminar" data-confirm="Segur que vols eliminar aquesta plantilla base?" data-form="del-base-content-{{ ct.id }}">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="cyber-cell text-center py-4">
                    <p class="field-help-text field-help-text--action">No hi ha plantilles base</p>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
</div>

{% endblock %}
