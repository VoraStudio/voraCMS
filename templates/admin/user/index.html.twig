{% extends 'admin/layout.html.twig' %}

{% block page_title %}Usuaris{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_user_new') }}" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg"></i> <span>Nou usuari</span>
</a>
{% endblock %}

{% block content %}
<div class="s-table-wrapper" style="background:var(--s-card-bg);border:1px solid var(--s-card-border);border-radius:var(--s-radius-lg);overflow:hidden;">
    <table class="s-table" style="width:100%;border-collapse:collapse;">
        <thead>
            <tr style="border-bottom:1px solid var(--s-card-border);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--s-text-secondary);">
                <th style="padding:12px 16px;text-align:left;">Nom</th>
                <th style="padding:12px 16px;text-align:left;">Email</th>
                <th style="padding:12px 16px;text-align:left;">Empresa</th>
                <th style="padding:12px 16px;text-align:center;">Rol</th>
                <th style="padding:12px 16px;text-align:center;">Projectes</th>
                <th style="padding:12px 16px;text-align:center;">Actiu</th>
                <th style="padding:12px 16px;text-align:right;">Accions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr class="{{ user.active ? 'row-active' : 'row-inactive' }}" style="border-bottom:1px solid var(--s-card-border);transition:background 0.15s;"
                onmouseover="this.style.background='var(--s-hover)'" onmouseout="this.style.background=''">
                <td style="padding:10px 16px;">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--s-accent-icon),var(--s-accent));display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.75rem;font-weight:600;flex-shrink:0;">
                            {{ user.name|first|upper }}
                        </div>
                        <div>
                            <div style="font-size:0.85rem;font-weight:500;color:var(--s-text);">{{ user.name }}</div>
                            <div style="font-size:0.65rem;color:var(--s-text-secondary);">slug: {{ user.slug }}</div>
                        </div>
                    </div>
                </td>
                <td style="padding:10px 16px;font-size:0.8rem;color:var(--s-text);">{{ user.email }}</td>
                <td style="padding:10px 16px;font-size:0.8rem;color:var(--s-text-secondary);">{{ user.company ?: '—' }}</td>
                <td style="padding:10px 16px;text-align:center;">
                    {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="badge" style="background:rgba(251,191,36,0.15);color:rgb(251,191,36);font-size:0.6rem;padding:4px 10px;border-radius:20px;">Admin</span>
                    {% elseif 'ROLE_MOD' in user.roles %}
                    <span class="badge" style="background:rgba(96,165,250,0.15);color:rgb(96,165,250);font-size:0.6rem;padding:4px 10px;border-radius:20px;">Mod</span>
                    {% else %}
                    <span class="badge" style="background:rgba(34,197,94,0.15);color:rgb(34,197,94);font-size:0.6rem;padding:4px 10px;border-radius:20px;">Usuari</span>
                    {% endif %}
                </td>
                <td style="padding:10px 16px;text-align:center;font-size:0.8rem;color:var(--s-text);">{{ userProjects[user.id] ?? 0 }}</td>
                <td style="padding:10px 16px;text-align:center;">
                    {% if user.active %}
                    <span style="color:rgb(34,197,94);font-size:1rem;">✓</span>
                    {% else %}
                    <span style="color:rgba(239,83,80,0.60);font-size:1rem;">✗</span>
                    {% endif %}
                </td>
                <td style="padding:10px 16px;text-align:right;white-space:nowrap;">
                    <div style="display:inline-flex;gap:4px;">
                        <form method="post" action="{{ path('admin_user_toggle_active', {id: user.id}) }}" style="display:inline" id="tact-user-{{ user.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle-active-' ~ user.id) }}">
                            <button type="submit"
                                    class="btn btn-sm {{ user.active ? 'btn-outline' : 'btn-primary' }}"
                                    style="padding:4px 10px;font-size:0.7rem;"
                                    title="{{ user.active ? 'Desactivar' : 'Activar' }}"
                                    {% if app.user.id == user.id %}disabled{% endif %}>
                                {{ user.active ? 'Desactivar' : 'Activar' }}
                            </button>
                        </form>
                        <a href="{{ path('admin_user_edit', {id: user.id}) }}"
                           class="btn btn-sm btn-outline-primary"
                           style="padding:4px 10px;font-size:0.7rem;">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" style="display:inline"
                              id="del-user-{{ user.id }}"
                              onsubmit="return confirm('Segur que vols eliminar aquest usuari?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.id) }}">
                            <button type="submit"
                                    class="btn btn-sm"
                                    style="padding:4px 10px;font-size:0.7rem;color:rgba(239,83,80,0.70);border-color:rgba(239,83,80,0.15);"
                                    {% if app.user.id == user.id or (userProjects[user.id] ?? 0) > 0 %}disabled title="{% if app.user.id == user.id %}No pots eliminar-te a tu mateix{% else %}Elimina primer els projectes{% endif %}"{% endif %}>
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" style="padding:60px 24px;text-align:center;color:var(--s-text-secondary);">
                    <i class="bi bi-people" style="font-size:2.5rem;display:block;margin-bottom:12px;opacity:0.3;"></i>
                    No hi ha usuaris
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
