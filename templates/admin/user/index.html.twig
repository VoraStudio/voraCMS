{% extends 'admin/layout.html.twig' %}

{% block page_title %}Usuaris{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_user_new') }}" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg"></i> <span>Nou usuari</span>
</a>
{% endblock %}

{% block content %}
<div class="s-table-wrapper" style="background:var(--s-card-bg);border:1px solid var(--s-card-border);border-radius:var(--s-radius-lg);overflow:hidden;">
    <table class="s-table" style="width:100%;border-collapse:collapse;">
        <thead>
            <tr style="border-bottom:1px solid var(--s-card-border);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--s-text-secondary);">
                <th style="padding:14px 18px;text-align:left;">Usuari</th>
                <th style="padding:14px 18px;text-align:left;">Email</th>
                <th style="padding:14px 18px;text-align:left;">Empresa</th>
                <th style="padding:14px 18px;text-align:center;">Rol</th>
                <th style="padding:14px 18px;text-align:center;">Projectes</th>
                <th style="padding:14px 18px;text-align:center;">Estat</th>
                <th style="padding:14px 18px;text-align:right;">Accions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr class="{{ user.active ? 'row-active' : 'row-inactive' }}" style="border-bottom:1px solid var(--s-card-border);transition:background 0.15s;"
                onmouseover="this.style.background='var(--s-hover)'" onmouseout="this.style.background=''">
                <td style="padding:12px 18px;">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--s-accent-icon),var(--s-accent));display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.85rem;font-weight:600;flex-shrink:0;">
                            {{ user.name|first|upper }}
                        </div>
                        <div>
                            <div style="font-size:0.85rem;font-weight:500;color:var(--s-text);">{{ user.name }}</div>
                            <div style="font-size:0.65rem;color:var(--s-text-secondary);">{{ user.slug }}</div>
                        </div>
                    </div>
                </td>
                <td style="padding:12px 18px;font-size:0.8rem;color:var(--s-text);">{{ user.email }}</td>
                <td style="padding:12px 18px;font-size:0.8rem;color:var(--s-text-secondary);">{{ user.company ?: '—' }}</td>
                <td style="padding:12px 18px;text-align:center;">
                    {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="badge" style="background:rgba(251,191,36,0.15);color:rgb(251,191,36);font-size:0.6rem;padding:4px 10px;border-radius:20px;">Admin</span>
                    {% elseif 'ROLE_MOD' in user.roles %}
                    <span class="badge" style="background:rgba(96,165,250,0.15);color:rgb(96,165,250);font-size:0.6rem;padding:4px 10px;border-radius:20px;">Mod</span>
                    {% else %}
                    <span class="badge" style="background:rgba(34,197,94,0.15);color:rgb(34,197,94);font-size:0.6rem;padding:4px 10px;border-radius:20px;">Usuari</span>
                    {% endif %}
                </td>
                <td style="padding:12px 18px;text-align:center;font-size:0.8rem;color:var(--s-text);">{{ userProjects[user.id] ?? 0 }}</td>
                <td style="padding:12px 18px;text-align:center;">
                    {% if user.active %}
                    <span style="display:inline-flex;align-items:center;gap:5px;color:rgb(34,197,94);font-size:0.75rem;font-weight:500;">
                        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:rgb(34,197,94);"></span> Actiu
                    </span>
                    {% else %}
                    <span style="display:inline-flex;align-items:center;gap:5px;color:rgba(239,83,80,0.70);font-size:0.75rem;font-weight:500;">
                        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:rgba(239,83,80,0.70);"></span> Inactiu
                    </span>
                    {% endif %}
                </td>
                <td style="padding:12px 18px;text-align:right;white-space:nowrap;">
                    <div style="display:inline-flex;gap:6px;align-items:center;">

                        {# ─── Veure projectes (indal: actiu=gradient viu, inactiu=pàlid) ─── #}
                        {% set proBtnBg = user.active
                            ? 'background:linear-gradient(135deg,#6366f1,#3b82f6);color:#fff;box-shadow:0 3px 10px rgba(99,102,241,0.35);'
                            : 'background:linear-gradient(135deg,rgba(99,102,241,0.25),rgba(59,130,246,0.15));color:rgba(148,163,184,0.6);box-shadow:none;' %}
                        <a href="{{ path('admin_projects', {user: user.id}) }}"
                           class="btn-projects"
                           data-active="{{ user.active ? '1' : '0' }}"
                           style="padding:6px 14px;font-size:0.7rem;border-radius:8px;display:inline-flex;align-items:center;gap:6px;border:none;cursor:pointer;text-decoration:none;transition:all 0.25s;font-weight:700;letter-spacing:0.02em;text-transform:uppercase;{{ proBtnBg }}"
                           onmouseover="this.style.background='linear-gradient(135deg,#4f46e5,#2563eb)';this.style.color='#fff';this.style.boxShadow='0 5px 14px rgba(99,102,241,0.45)';this.style.transform='translateY(-2px)scale(1.03)'"
                           onmouseout="this.style.transform='';this.style.background='{{ user.active
                                ? 'linear-gradient(135deg,#6366f1,#3b82f6)'
                                : 'linear-gradient(135deg,rgba(99,102,241,0.25),rgba(59,130,246,0.15))' }}';this.style.color='{{ user.active ? '#fff' : 'rgba(148,163,184,0.6)' }}';this.style.boxShadow='{{ user.active ? '0 3px 10px rgba(99,102,241,0.35)' : 'none' }}'">
                            <i class="bi bi-folder2-open" style="font-size:0.75rem;"></i>
                            <span>Projectes</span>
                        </a>

                        {# ─── Separador ─── #}
                        <span style="width:1px;height:26px;background:var(--s-card-border);display:inline-block;"></span>

                        {# ─── Toggle active ─── #}
                        {% set togBg = user.active
                            ? 'linear-gradient(135deg,#22c55e,#16a34a)'
                            : 'linear-gradient(135deg,#ef4444,#dc2626)' %}
                        {% set togShad = user.active
                            ? 'rgba(34,197,94,0.35)'
                            : 'rgba(239,68,68,0.35)' %}
                        {% set togShadHov = user.active
                            ? 'rgba(34,197,94,0.45)'
                            : 'rgba(239,68,68,0.45)' %}
                        <form method="post" action="{{ path('admin_user_toggle_active', {id: user.id}) }}" style="display:inline" id="tact-user-{{ user.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle-active-' ~ user.id) }}">
                            <button type="submit"
                                    class="btn-toggle"
                                    data-active="{{ user.active ? '1' : '0' }}"
                                    style="width:34px;height:34px;border-radius:8px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all 0.25s;padding:0;background:{{ togBg }};color:#fff;box-shadow:0 3px 8px {{ togShad }};"
                                    title="{{ user.active ? 'Desactivar' : 'Activar' }}"
                                    {% if app.user.id == user.id %}disabled style="opacity:0.3;cursor:not-allowed;background:linear-gradient(135deg,#555,#444);color:#888;box-shadow:none;"{% endif %}
                                    onmouseover="if(!this.disabled){this.style.transform='scale(1.12)';this.style.boxShadow='0 5px 12px {{ togShadHov }}'}"
                                    onmouseout="if(!this.disabled){this.style.transform='';this.style.boxShadow='0 3px 8px {{ togShad }}'}">
                                <i class="bi {{ user.active ? 'bi-toggle2-on' : 'bi-toggle2-off' }}" style="font-size:1.1rem;"></i>
                            </button>
                        </form>

                        {# ─── Editar ─── #}
                        <a href="{{ path('admin_user_edit', {id: user.id}) }}"
                           style="width:34px;height:34px;border-radius:8px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;transition:all 0.25s;padding:0;background:linear-gradient(135deg,#6366f1,#3b82f6);color:#fff;box-shadow:0 3px 8px rgba(99,102,241,0.35);"
                           title="Editar"
                           onmouseover="this.style.background='linear-gradient(135deg,#4f46e5,#2563eb)';this.style.transform='scale(1.12)';this.style.boxShadow='0 5px 12px rgba(99,102,241,0.45)'"
                           onmouseout="this.style.background='linear-gradient(135deg,#6366f1,#3b82f6)';this.style.transform='';this.style.boxShadow='0 3px 8px rgba(99,102,241,0.35)'">
                            <i class="bi bi-pencil" style="font-size:0.85rem;"></i>
                        </a>

                        {# ─── Eliminar ─── #}
                        <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" style="display:inline"
                              id="del-user-{{ user.id }}"
                              onsubmit="return confirm('Segur que vols eliminar aquest usuari?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.id) }}">
                            <button type="submit"
                                    style="width:34px;height:34px;border-radius:8px;border:none;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all 0.25s;padding:0;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;box-shadow:0 3px 8px rgba(239,68,68,0.35);"
                                    title="Eliminar"
                                    {% if app.user.id == user.id or (userProjects[user.id] ?? 0) > 0 %}
                                    disabled style="opacity:0.3;cursor:not-allowed;background:linear-gradient(135deg,#555,#444);color:#888;box-shadow:none;"
                                    {% endif %}
                                    onmouseover="if(!this.disabled){this.style.background='linear-gradient(135deg,#dc2626,#b91c1c)';this.style.transform='scale(1.12)';this.style.boxShadow='0 5px 12px rgba(239,68,68,0.45)'}"
                                    onmouseout="if(!this.disabled){this.style.background='linear-gradient(135deg,#ef4444,#dc2626)';this.style.transform='';this.style.boxShadow='0 3px 8px rgba(239,68,68,0.35)'}">
                                <i class="bi bi-trash3" style="font-size:0.85rem;"></i>
                            </button>
                        </form>

                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" style="padding:60px 24px;text-align:center;color:var(--s-text-secondary);">
                    <i class="bi bi-people" style="font-size:2.5rem;display:block;margin-bottom:12px;opacity:0.3;"></i>
                    No hi ha usuaris
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
