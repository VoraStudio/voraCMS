{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ isNew ? 'Nou usuari' : 'Editar usuari' }}{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_user_index') }}" class="cyber-btn cyber-btn--projects">
    <i class="bi bi-arrow-left"></i> <span>Tornar</span>
</a>
{% endblock %}

{% block content %}
<div class="cyber-form-card">
    <div class="cyber-card cyber-card--flush" data-anim="cyber-card">
        <div class="cyber-form-header">
            <div class="cyber-form-header-icon">
                <i class="bi {{ isNew ? 'bi-person-plus-fill' : 'bi-person-fill-gear' }}"></i>
            </div>
            <div>
                <h2 class="cyber-section-title">{{ isNew ? 'Nou usuari' : 'Editar usuari' }}</h2>
                <p class="cyber-section-desc">{{ isNew ? 'Crea un nou usuari al sistema' : 'Modifica les dades de l\'usuari' }}</p>
            </div>
        </div>
        <form method="post" action="{{ isNew ? path('admin_user_new') : path('admin_user_edit', {id: user.id}) }}" class="cyber-form-body">

            <div class="cyber-form-group">
                <label class="cyber-form-label">Nom</label>
                <input type="text" name="name" value="{{ user.name ?: '' }}" required
                       class="cyber-form-input" placeholder="Nom de l'usuari">
            </div>

            <div class="cyber-form-group">
                <label class="cyber-form-label">Email</label>
                <input type="email" name="email" value="{{ user.email ?: '' }}" required
                       class="cyber-form-input" placeholder="email@exemple.com">
            </div>

            <div class="cyber-form-group">
                <label class="cyber-form-label">Empresa</label>
                <input type="text" name="company" value="{{ user.company ?: '' }}"
                       class="cyber-form-input" placeholder="Nom de l'empresa (opcional)">
            </div>

            <div class="cyber-form-group">
                <label class="cyber-form-label">Slug <span class="cyber-form-label__hint">(identificador únic)</span></label>
                <input type="text" name="slug" value="{{ user.slug ?: '' }}"
                       class="cyber-form-input" placeholder="slug-de-l-usuari"
                       {{ isNew ? 'readonly class="cyber-form-input cyber-form-input--readonly" title="Es genera automàticament des de l\'empresa"' : '' }}>
            </div>

            <div class="cyber-form-group">
                <label class="cyber-form-label">
                    Contrasenya {% if not isNew %}<span class="cyber-form-label__hint">(deixar buit per no canviar)</span>{% endif %}
                </label>
                <input type="password" name="password" class="cyber-form-input"
                       placeholder="{{ isNew ? 'Contrasenya' : 'Deixar buit = no canviar' }}"
                       {{ isNew ? 'required' : '' }}>
            </div>

            <div class="cyber-form-group">
                <label class="cyber-form-label">Rol</label>
                <select name="role" class="cyber-form-input cyber-form-input--select">
                    <option value="ROLE_USUARIO" {{ user.roles[0] is defined and user.roles[0] == 'ROLE_USUARIO' ? 'selected' : '' }}>Usuari</option>
                    <option value="ROLE_MOD" {{ user.roles[0] is defined and user.roles[0] == 'ROLE_MOD' ? 'selected' : '' }}>Moderador</option>
                    <option value="ROLE_ADMIN" {{ user.roles[0] is defined and user.roles[0] == 'ROLE_ADMIN' ? 'selected' : '' }}>Admin</option>
                </select>
            </div>

            <div class="cyber-form-group">
                <label class="cyber-form-label">Dominis permesos (API)</label>
                <textarea name="allowed_domains" class="cyber-form-input"
                          placeholder="Un domini per línia&#10;ex: vorastudio.cat" rows="3">{{ user.allowedDomains is not null ? user.allowedDomains|join("\n") : '' }}</textarea>
                <p class="cyber-form-hint" style="font-size:0.85rem;color:var(--s-muted);margin-top:4px">
                    Els JWT només seran vàlids des d'aquests dominis. Deixa buit = sense restricció.
                </p>
            </div>

            <div class="cyber-form-group">
                <label class="s-toggle s-toggle--chk" style="--s-toggle-color:var(--s-accent)">
                    <input type="checkbox" name="active" value="1"
                           class="s-toggle__inp-cb"
                           {{ user.id is null or user.active ? 'checked' : '' }}>
                    <span class="s-toggle__switch"></span>
                    <span class="s-toggle__icon"><i class="bi bi-person-check"></i></span>
                    <span class="s-toggle__lbl-cb s-toggle__lbl-cb--off">Inactiu</span>
                    <span class="s-toggle__lbl-cb s-toggle__lbl-cb--on">Actiu</span>
                </label>
            </div>

            <button type="submit" class="cyber-form-submit" data-anim="cyber-btn">
                <i class="bi bi-check-lg"></i> <span>{{ isNew ? 'Crear usuari' : 'Guardar canvis' }}</span>
            </button>
        </form>
    </div>
</div>
{% include 'admin/components/_help_faq.html.twig' with { form_context: 'user' } %}
{% endblock %}
