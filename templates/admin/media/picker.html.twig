{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/reset.css') }}">
<link rel="stylesheet" href="{{ asset('css/root.css') }}">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
<div class="media-picker-body">
<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="mb-0">
        {% if multiple %}
        Selecciona imatges
        {% else %}
        Selecciona una imatge
        {% endif %}
    </h6>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-secondary" id="closeBtn">Tancar</button>
        <button type="button" class="btn btn-sm btn-primary" id="selectBtn" disabled><span>Seleccionar</span></button>
    </div>
</div>

{# ─── Upload form ─── #}
<div class="card media-picker-upload mb-3">
    <div class="card-body p-3">
        <form id="uploadForm" enctype="multipart/form-data" class="media-picker-upload__form" data-upload-url="{{ path('admin_media_upload') }}">
            <input type="file" name="files[]" class="form-control form-control-sm media-picker-upload__file-input" accept=".jpg,.jpeg,.webp,.avif" multiple>
            {% if project %}
            <input type="hidden" name="project_id" value="{{ project.id }}">
            {% endif %}
            <button type="submit" class="btn btn-sm btn-primary" id="uploadBtn"><i class="bi bi-cloud-upload"></i> <span>Pujar</span></button>
        </form>
        <div id="uploadMsg" class="mt-2 small media-picker-upload__msg"></div>
    </div>
</div>

<div class="row g-2" id="mediaGrid">
    {% for m in media %}
    <div class="col-4 col-md-3">
        <div class="media-picker-item card p-1 text-center" data-id="{{ m.id }}" data-url="{{ m.path }}">
            <div class="media-picker-item__thumb">
                <img src="{{ m.path }}" alt="{{ m.originalFilename }}">
                <div class="media-picker-item__check"><i class="bi bi-check"></i></div>
            </div>
            <small class="text-truncate d-block mt-1 media-picker-item__filename">{{ m.originalFilename }}</small>
        </div>
    </div>
    {% else %}
    <div class="col-12 text-center py-4 media-picker-empty">
        <p>No hi ha imatges encara.</p>
    </div>
    {% endfor %}
</div>
</div>

<div id="mediaPickerConfig"
     data-field-id="{{ fieldId }}"
     data-multiple="{{ multiple ? 'true' : 'false' }}"
     class="d-none"></div>

<script src="{{ asset('js/media-picker.js') }}"></script>
{% endblock %}
