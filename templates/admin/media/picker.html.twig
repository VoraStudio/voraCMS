{% extends 'base.html.twig' %}

{% block stylesheets %}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="{{ asset('css/admin.css') }}">
<style>
  body { padding: 16px; background: #fff; }
  .media-item { cursor: pointer; border: 2px solid transparent; transition: all .15s; }
  .media-item:hover { border-color: var(--s-primary); }
  .media-item.selected { border-color: var(--s-primary); background: var(--s-primary-bg); }
</style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="mb-0">Selecciona una imatge</h6>
    <button type="button" class="btn btn-sm btn-outline-primary" onclick="window.parent.closePicker()">Tancar</button>
</div>

<div class="row g-2">
    {% for m in media %}
    <div class="col-4 col-md-3">
        <div class="media-item card p-1 text-center" data-id="{{ m.id }}" data-url="{{ m.path }}">
            <div style="aspect-ratio:1;overflow:hidden;background:var(--s-bg);border-radius:3px;">
                <img src="{{ m.path }}" alt="{{ m.originalFilename }}" class="w-100 h-100" style="object-fit:cover;">
            </div>
            <small class="text-truncate d-block mt-1">{{ m.originalFilename }}</small>
        </div>
    </div>
    {% else %}
    <div class="col-12 text-center py-4" style="color:var(--s-text-secondary);">
        <p>No hi ha imatges. <a href="{{ path('admin_media_index') }}" target="_blank">Puja'n una</a></p>
    </div>
    {% endfor %}
</div>

<script>
var FIELD_ID = '{{ fieldId }}';

document.querySelectorAll('.media-item').forEach(function(el) {
    el.addEventListener('click', function() {
        document.querySelectorAll('.media-item').forEach(function(i) { i.classList.remove('selected'); });
        this.classList.add('selected');
        window.parent.postMessage({
            type: 'media-pick',
            fieldId: "{{ fieldId }}",
            id: this.dataset.id,
            url: this.dataset.url
        }, '*');
    });
});
</script>
{% endblock %}
