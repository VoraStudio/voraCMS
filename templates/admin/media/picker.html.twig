{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/admin/theme.css') }}?v=2.0">
<link rel="stylesheet" href="{{ asset('css/admin/media.css') }}">
<script>try { var t = localStorage.getItem('voracms_theme'); if (t === 'light') document.documentElement.setAttribute('data-theme', 'light'); } catch(e) {}</script>
{% endblock %}

{% block body %}
<div class="media-picker-body">
    {# ─── Top bar ─── #}
    <div class="media-picker__topbar">
        <h6 class="media-picker__title">
            {% if multiple %}
            <i class="bi bi-images"></i> Selecciona imatges
            {% else %}
            <i class="bi bi-image"></i> Selecciona una imatge
            {% endif %}
        </h6>
        <div class="media-picker__topbar-actions">
            <button type="button" class="media-picker__send-btn" id="selectBtnTop" disabled>
                <i class="bi bi-check2"></i> <span>Enviar</span>
            </button>
            <button type="button" class="media-picker__close-btn" id="closeBtn" aria-label="Tancar">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>

    {# ─── Upload area ─── #}
    <div class="media-picker__upload">
        <form id="uploadForm" enctype="multipart/form-data" data-upload-url="{{ path('admin_media_upload') }}">
            <div class="media-picker__upload-inner">
                <i class="bi bi-cloud-upload media-picker__upload-icon"></i>
                <label class="media-picker__upload-label">
                    <input type="file" name="files[]" class="media-picker__file-input" accept=".jpg,.jpeg,.png,.webp,.avif" multiple>
                    <span>Arrossega o selecciona fitxers</span>
                </label>
                {% if project %}
                <input type="hidden" name="project_id" value="{{ project.id }}">
                {% endif %}
                <button type="submit" class="media-picker__upload-btn" id="uploadBtn">
                    <i class="bi bi-cloud-arrow-up"></i> Pujar
                </button>
            </div>
            <div id="uploadPreview" class="media-picker__preview"></div>
            <div id="uploadMsg" class="media-picker__upload-msg"></div>
        </form>
    </div>

    {# ─── Client → Project accordion ─── #}
    <div class="media-picker__projects">
        {% for group in mediaGrouped %}
        {# ── Client card ── #}
        <div class="media-picker__client" data-client="{{ group.company }}">
            <div class="media-picker__client-header">
                <span class="media-picker__client-header-left">
                    <i class="bi bi-building media-picker__client-icon"></i>
                    <span class="media-picker__client-name">{{ group.company }}</span>
                </span>
            </div>

            {% for pgroup in group.projects %}
            {% set p = pgroup.project -%}
            <div class="media-picker__card">
                <button type="button" class="media-picker__card-header" onclick="toggleCard(this)" data-project-id="{{ p ? p.id : 'none' }}" aria-expanded="false">
                    <span class="media-picker__card-header-left">
                        {% if p %}
                        <span class="media-picker__card-dot" style="background: {{ p.color }}"></span>
                        <span class="media-picker__card-name">{{ p.name }}</span>
                        {% else %}
                        <i class="bi bi-folder media-picker__card-folder"></i>
                        <span class="media-picker__card-name">Sense projecte</span>
                        {% endif %}
                    </span>
                    <span class="media-picker__card-header-right">
                        <span class="media-picker__card-count">{{ pgroup.items|length }}</span>
                        <i class="bi bi-chevron-down media-picker__card-arrow"></i>
                    </span>
                </button>
                <div class="media-picker__card-body" role="region">
                    <div class="media-picker__grid">
                        {% for m in pgroup.items %}
                        <div class="media-picker__item" data-id="{{ m.id }}" data-url="{{ m.path }}" data-delete-url="{{ path('admin_media_delete', {id: m.id}) }}" data-csrf-token="{{ csrf_token('delete' ~ m.id) }}" role="option" aria-selected="false">
                            <div class="media-picker__item-thumb">
                                <img src="{{ m.path }}" alt="{{ m.originalFilename }}" loading="lazy">
                                <button type="button" class="media-picker__item-delete" aria-label="Eliminar imatge" title="Eliminar"><i class="bi bi-x"></i></button>
                                <div class="media-picker__item-check"><i class="bi bi-check-lg"></i></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="media-picker__empty">
            <i class="bi bi-gallery"></i>
            <p>No hi ha imatges encara.</p>
        </div>
        {% endfor %}
    </div>

    {# ─── Sticky send button ─── #}
    <div class="media-picker__footer">
        <div class="media-picker__footer-inner">
            <span class="media-picker__footer-count" id="selectedCount"></span>
            <button type="button" class="media-picker__send-btn" id="selectBtnBottom" disabled>
                <i class="bi bi-check2"></i> <span>Enviar</span>
            </button>
        </div>
    </div>
</div>

<div id="mediaPickerConfig"
     data-field-id="{{ fieldId }}"
     data-multiple="{{ multiple ? 'true' : 'false' }}"
     class="media-picker__config"></div>

<script>
function toggleCard(header) {
  var card = header.closest('.media-picker__card');
  if (!card) return;

  var isOpen = header.getAttribute('aria-expanded') === 'true';

  document.querySelectorAll('.media-picker__card--open').forEach(function (c) {
    if (c !== card) {
      c.classList.remove('media-picker__card--open');
      var ch = c.querySelector('.media-picker__card-header');
      if (ch) ch.setAttribute('aria-expanded', 'false');
    }
  });

  if (isOpen) {
    card.classList.remove('media-picker__card--open');
    header.setAttribute('aria-expanded', 'false');
  } else {
    card.classList.add('media-picker__card--open');
    header.setAttribute('aria-expanded', 'true');
  }
}
</script>
<script src="{{ asset('js/media-picker.js') }}?v=3.0"></script>
{% endblock %}
