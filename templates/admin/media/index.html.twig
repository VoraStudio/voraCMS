{% extends 'admin/layout.html.twig' %}

{% block page_title %}Mediateca{% endblock %}

{% block topbar_actions %}{% endblock %}

{% block content %}
<div class="media-index">
  {# ─── Upload area (inline drag-drop) ─── #}
  <div class="media-picker__upload">
    <form id="uploadForm" enctype="multipart/form-data" data-upload-url="{{ path('admin_media_upload') }}">
      <div class="media-picker__upload-inner">
        <i class="bi bi-cloud-upload media-picker__upload-icon"></i>
        <label class="media-picker__upload-label">
          <input type="file" name="files[]" class="media-picker__file-input" accept=".jpg,.jpeg,.webp,.avif" multiple>
          <span>Arrossega o selecciona fitxers</span>
        </label>
        {% if groupedMode and projectGroups|length > 0 %}
        <select name="project_id" class="media-index__project-select">
          <option value="">Sense projecte</option>
          {% for company, users in projectGroups %}
          {% for userLabel, projects in users %}
          <optgroup label="{{ company }} — {{ userLabel }}">
            {% for p in projects %}
            <option value="{{ p.id }}">{{ p.name }}</option>
            {% endfor %}
          </optgroup>
          {% endfor %}
          {% endfor %}
        </select>
        {% endif %}
        <button type="submit" class="media-picker__upload-btn" id="uploadBtn">
          <i class="bi bi-cloud-arrow-up"></i> Pujar
        </button>
      </div>
      <div id="uploadPreview" class="media-picker__preview"></div>
      <div id="uploadMsg" class="media-picker__upload-msg"></div>
    </form>
  </div>

  {# ─── Batch toolbar (hidden per defecte) ─── #}
  <div class="media-index__batch-toolbar" id="batchToolbar" hidden>
    <span class="media-index__batch-count" id="batchCount">0 seleccionades</span>
    <button type="button" class="media-index__batch-move" id="batchMoveBtn">
      <i class="bi bi-folder-symlink"></i> Mou al projecte
    </button>
    <button type="button" class="media-index__batch-clear" id="batchClearBtn">
      <i class="bi bi-x-lg"></i> Desseleccionar
    </button>
  </div>

  {# ─── Form ocult per al batch move ─── #}
  <form id="batchMoveForm" method="post" action="{{ path('admin_media_batch_move') }}" class="d-none">
    <input type="hidden" name="_token" value="{{ csrf_token('batch-move') }}">
    <input type="hidden" name="project_id" id="batchProjectId" value="">
  </form>

  {# ─── Client → Project accordion ─── #}
  <div class="media-picker__projects" id="mediaBrowser">

    {% if groupedMode %}
      {# ─── Admin: per client → projecte ─── #}
      {% for group in media %}
      <div class="media-picker__client" data-client="{{ group.company }}">
        <div class="media-picker__client-header">
          <span class="media-picker__client-header-left">
            <i class="bi bi-building media-picker__client-icon"></i>
            <span class="media-picker__client-name">{{ group.company }}</span>
          </span>
        </div>

        {% for pk, pgroup in group.projects %}
        {% set p = pgroup.project %}
        <div class="media-picker__card">
          <button type="button" class="media-picker__card-header js-toggle-card" data-project-id="{{ p ? p.id : 'none' }}" aria-expanded="false">
            <span class="media-picker__card-header-left">
              {% if p and p.color %}
              <span class="media-picker__card-dot" style="background: {{ p.color }}"></span>
              {% elseif p %}
              <i class="bi bi-folder media-picker__card-folder"></i>
              {% else %}
              <i class="bi bi-folder media-picker__card-folder"></i>
              {% endif %}
              <span class="media-picker__card-name">{{ p ? p.name : 'Sense projecte' }}</span>
            </span>
            <span class="media-picker__card-header-right">
              <span class="media-picker__card-count">{{ pgroup.count }}</span>
              <i class="bi bi-chevron-down media-picker__card-arrow"></i>
            </span>
          </button>
          <div class="media-picker__card-body" role="region">
            <div class="media-picker__grid">
              {% for m in pgroup.items %}
              <div class="media-picker__item media-index__item" data-id="{{ m.id }}" data-url="{{ m.path }}">
                <div class="media-picker__item-thumb">
                  <label class="media-index__item-check">
                    <input type="checkbox" name="media_ids[]" value="{{ m.id }}" class="js-media-check">
                  </label>
                  <img src="{{ m.path }}" alt="{{ m.originalFilename }}" loading="lazy">
                  <button type="button" class="media-picker__item-delete" aria-label="Eliminar imatge" title="Eliminar"
                    data-confirm="Eliminaràs «{{ m.originalFilename }}». Aquesta acció no es pot desfer."
                    data-form="del-media-{{ m.id }}"><i class="bi bi-x"></i></button>
                  <form method="post" action="{{ path('admin_media_delete', {'id': m.id }) }}" id="del-media-{{ m.id }}" class="d-none">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ m.id) }}">
                  </form>
                </div>
                <div class="media-index__item-info">
                  <span class="media-index__item-name" title="{{ m.originalFilename }}">{{ m.originalFilename }}</span>
                  <span class="media-index__item-size">{{ (m.fileSize / 1024)|number_format(1, ',', ' ') }} KB</span>
                </div>
                <button class="media-index__item-copy" data-url="{{ m.path }}" title="Copiar URL">
                  <i class="bi bi-link-45deg"></i>
                </button>
              </div>
              {% else %}
              <div class="media-picker__empty" style="width:100%">
                <p>No hi ha imatges en aquest projecte.</p>
              </div>
              {% endfor %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="media-picker__empty">
        <i class="bi bi-images"></i>
        <p>No hi ha imatges encara.</p>
      </div>
      {% endfor %}

    {% else %}
      {# ─── Usuari normal: un sol client virtual ─── #}
      {% for group in media %}
      <div class="media-picker__client" data-client="{{ group.company }}">
        <div class="media-picker__client-header">
          <span class="media-picker__client-header-left">
            <i class="bi bi-building media-picker__client-icon"></i>
            <span class="media-picker__client-name">{{ group.company }}</span>
          </span>
        </div>

        {% for pk, pgroup in group.projects %}
        {% set p = pgroup.project %}
        <div class="media-picker__card">
          <button type="button" class="media-picker__card-header js-toggle-card" data-project-id="{{ p ? p.id : 'none' }}" aria-expanded="false">
            <span class="media-picker__card-header-left">
              {% if p and p.color %}
              <span class="media-picker__card-dot" style="background: {{ p.color }}"></span>
              {% elseif p %}
              <i class="bi bi-folder media-picker__card-folder"></i>
              {% else %}
              <i class="bi bi-folder media-picker__card-folder"></i>
              {% endif %}
              <span class="media-picker__card-name">{{ p ? p.name : 'Sense projecte' }}</span>
            </span>
            <span class="media-picker__card-header-right">
              <span class="media-picker__card-count">{{ pgroup.count }}</span>
              <i class="bi bi-chevron-down media-picker__card-arrow"></i>
            </span>
          </button>
          <div class="media-picker__card-body" role="region">
            <div class="media-picker__grid">
              {% for m in pgroup.items %}
              <div class="media-picker__item media-index__item" data-id="{{ m.id }}" data-url="{{ m.path }}">
                <div class="media-picker__item-thumb">
                  <label class="media-index__item-check">
                    <input type="checkbox" name="media_ids[]" value="{{ m.id }}" class="js-media-check">
                  </label>
                  <img src="{{ m.path }}" alt="{{ m.originalFilename }}" loading="lazy">
                  <button type="button" class="media-picker__item-delete" aria-label="Eliminar imatge" title="Eliminar"
                    data-confirm="Eliminaràs «{{ m.originalFilename }}». Aquesta acció no es pot desfer."
                    data-form="del-media-{{ m.id }}"><i class="bi bi-x"></i></button>
                  <form method="post" action="{{ path('admin_media_delete', {'id': m.id }) }}" id="del-media-{{ m.id }}" class="d-none">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ m.id) }}">
                  </form>
                </div>
                <div class="media-index__item-info">
                  <span class="media-index__item-name" title="{{ m.originalFilename }}">{{ m.originalFilename }}</span>
                  <span class="media-index__item-size">{{ (m.fileSize / 1024)|number_format(1, ',', ' ') }} KB</span>
                </div>
                <button class="media-index__item-copy" data-url="{{ m.path }}" title="Copiar URL">
                  <i class="bi bi-link-45deg"></i>
                </button>
              </div>
              {% else %}
              <div class="media-picker__empty" style="width:100%">
                <p>No hi ha imatges en aquest projecte.</p>
              </div>
              {% endfor %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="media-picker__empty">
        <i class="bi bi-images"></i>
        <p>No hi ha imatges encara.</p>
      </div>
      {% endfor %}
    {% endif %}

  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% include 'admin/components/_help_faq.html.twig' with { form_context: 'media_index' } %}
<script src="{{ asset('js/media-index.js') }}?v=3.0"></script>
{% endblock %}
