{% extends 'admin/layout.html.twig' %}

{% block page_title %}Editar: {{ contentType.name }}{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_content_type_index') }}" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-arrow-left"></i> Tornar
</a>
{% endblock %}

{% block content %}
<div class="card">
    <div class="card-body">
        <form method="post">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Nom</label>
                    <input type="text" name="name" class="form-control" value="{{ contentType.name }}" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Slug</label>
                    <input type="text" class="form-control" value="{{ contentType.slug }}" disabled>
                    <small style="color:var(--s-text-secondary);">No es pot canviar</small>
                </div>
                <div class="col-12">
                    <label class="form-label">Descripció</label>
                    <textarea name="description" class="form-control" rows="2">{{ contentType.description }}</textarea>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input type="checkbox" name="active" class="form-check-input" {% if contentType.active %}checked{% endif %} value="1">
                        <label class="form-check-label">Actiu</label>
                    </div>
                </div>
            </div>

            <hr style="border-color:var(--s-card-border);opacity:0.5;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0 fw-semibold">Camps</h6>
                <button type="button" class="btn btn-outline-primary btn-sm" id="addFieldBtn"><i class="bi bi-plus-lg"></i> Afegir camp</button>
            </div>

            <div id="fieldsContainer">
                {% for field in contentType.fields %}
                <div class="s-field-group row g-2 field-row">
                    <div class="col-md-4">
                        <input type="text" name="field_name[]" class="form-control form-control-sm" value="{{ field.name }}" placeholder="Nom del camp">
                    </div>
                    <div class="col-md-3">
                        <select name="field_type[]" class="form-select form-select-sm">
                            {% for type in fieldTypes %}
                            <option value="{{ type }}" {% if field.fieldType == type %}selected{% endif %}>{{ type }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-center">
                        <div class="form-check">
                            <input type="checkbox" name="field_required[]" class="form-check-input" {% if field.required %}checked{% endif %} value="1">
                            <label class="form-check-label small">Requerit</label>
                        </div>
                    </div>
                    <div class="col-md-2 text-end">
                        <button type="button" class="btn btn-outline-danger btn-sm remove-field"><i class="bi bi-x"></i></button>
                    </div>
                </div>
                {% endfor %}
            </div>

            <hr class="mt-4" style="border-color:var(--s-card-border);opacity:0.5;">
            <button type="submit" class="btn btn-primary w-100"><span>Guardar canvis</span></button>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('addFieldBtn').addEventListener('click', function() {
        var container = document.getElementById('fieldsContainer');
        var row = container.querySelector('.field-row').cloneNode(true);
        row.querySelectorAll('input').forEach(function(i) { i.value = ''; });
        row.querySelectorAll('input[type="checkbox"]').forEach(function(c) { c.checked = false; });
        container.appendChild(row);
    });
    document.addEventListener('click', function(e) {
        if (e.target.closest('.remove-field')) {
            var rows = document.querySelectorAll('.field-row');
            if (rows.length > 1) e.target.closest('.field-row').remove();
        }
    });
});
</script>
{% endblock %}
