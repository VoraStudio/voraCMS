{% extends 'admin/layout.html.twig' %}

{% block page_title %}Tipus de contingut{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_content_type_new') }}" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg"></i> <span>Nou tipus</span>
</a>
{% endblock %}

{% block content %}
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Slug</th>
                    <th>Camps</th>
                    <th>Entrades</th>
                    <th>Actiu</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for ct in contentTypes %}
                <tr class="{{ ct.active ? 'row-active' : 'row-inactive' }}">
                    <td class="text-capitalize fw-semibold">{{ ct.name }}</td>
                    <td><code>{{ ct.slug }}</code></td>
                    <td>{{ ct.fields|length }}</td>
                    <td>{{ ct.entries|length }}</td>
                    <td>
                        {% if ct.active %}
                            <span class="badge bg-success">Sí</span>
                        {% else %}
                            <span class="badge bg-secondary">No</span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <a href="{{ path('admin_content_type_edit', {id: ct.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('admin_content_type_toggle_active', {id: ct.id}) }}" style="display:inline" id="tact-ct-{{ ct.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle-active-' ~ ct.id) }}">
                            <button type="submit" class="btn btn-sm {{ ct.active ? 'btn-outline-secondary' : 'btn-outline-success' }}" title="{{ ct.active ? 'Desactivar' : 'Activar' }}">
                                {{ ct.active ? 'Desactivar' : 'Activar' }}
                            </button>
                        </form>
                        <form method="post" action="{{ path('admin_content_type_delete', {id: ct.id}) }}" style="display:inline" id="dct-{{ ct.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ct.id) }}">
                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="swalConfirm('Segur que vols eliminar aquest tipus i totes les seves entrades?',function(){document.getElementById('dct-{{ ct.id }}').submit()})"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
