{% extends 'admin/layout.html.twig' %}

{% block page_title %}Tipus de contingut{% endblock %}

{% block topbar_actions %}
<div class="d-flex gap-2">
    <a href="{{ path('admin_content_type_new') }}" class="cyber-btn cyber-btn--projects" data-anim="cyber-btn">
        <i class="bi bi-plus-lg"></i> <span>Nou tipus</span>
    </a>
    <a href="{{ path('admin_base_content_new') }}" class="cyber-btn cyber-btn--projects" data-anim="cyber-btn">
        <i class="bi bi-window-stack"></i> <span>Nova plantilla global</span>
    </a>
</div>
{% endblock %}

{% block content %}
<div class="cyber-form-card">
{% include 'admin/components/_section_header.html.twig' with {
    title: 'Tipus de contingut',
    description: 'Totes les seccions de contingut de tots els projectes',
    icon: 'bi-layers-fill',
    stats: [
        {value: contentTypes|length, label: 'Total'},
        {value: contentTypes|filter(ct => ct.active)|length, label: 'Actius', modifier: 'active'}
    ]
} %}

<div class="cyber-card cyber-card--table cyber-card--flush" data-anim="cyber-card">
    <table class="cyber-table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Slug</th>
                <th>Projecte</th>
                <th>Camps</th>
                <th>Entrades</th>
                <th>Actiu</th>
                <th>Accions</th>
            </tr>
        </thead>
        <tbody>
        {% for ct in contentTypes %}
            <tr class="cyber-row {{ ct.active ? 'row-active' : 'row-inactive' }}" data-anim="cyber-row">
                <td class="cyber-cell text-capitalize fw-semibold">{{ ct.name }}</td>
                <td class="cyber-cell"><code>{{ ct.slug }}</code></td>
                <td class="cyber-cell">{% if ct.base %}<span class="badge bg-warning bg-opacity-10 text-warning">Global</span>{% else %}<span class="badge bg-info bg-opacity-10 text-info">Personalitzat</span>{% endif %}</td>
                <td class="cyber-cell cyber-cell--numeric">{{ ct.fields|length }}</td>
                <td class="cyber-cell cyber-cell--numeric">{{ ct.entries|length }}</td>
                <td class="cyber-cell cyber-cell--status">
                    {% include 'admin/components/_status.html.twig' with {active: ct.active} %}
                </td>
                <td class="cyber-cell cyber-cell--actions">
                    <div class="cyber-actions">
                        <a href="{{ path('admin_entry_by_type', {slug: ct.slug}) }}"
                           class="cyber-btn cyber-btn--icon" title="Veure entrades">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="{{ path('admin_content_type_edit', {id: ct.id}) }}"
                           class="cyber-btn cyber-btn--icon cyber-btn--edit" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <span class="cyber-actions-divider"></span>
                        {% include 'admin/components/_toggle_btn.html.twig' with {
                            formId: 'tact-ct-' ~ ct.id,
                            csrfToken: csrf_token('toggle-active-' ~ ct.id),
                            route: path('admin_content_type_toggle_active', {id: ct.id}),
                            active: ct.active
                        } %}
                        <form method="post" action="{{ path('admin_content_type_delete', {id: ct.id}) }}" class="cyber-form--inline"
                              id="del-ct-{{ ct.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ct.id) }}">
                            <button type="button"
                                    class="cyber-btn cyber-btn--icon cyber-btn--delete"
                                    title="Eliminar"
                                    data-confirm="Segur que vols eliminar aquest tipus i totes les seves entrades?"
                                    data-form="del-ct-{{ ct.id }}">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7" class="cyber-empty">
                    <div class="cyber-empty-icon"><i class="bi bi-layers"></i></div>
                    <p class="cyber-empty-text">No hi ha tipus de contingut</p>
                    <a href="{{ path('admin_content_type_new') }}" class="cyber-btn-primary cyber-btn--action">
                        <i class="bi bi-plus-lg"></i> <span>Crear primer tipus</span>
                    </a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
</div>

{% endblock %}
