{% extends 'admin/layout.html.twig' %}

{% set breadcrumbs = [
    {label: 'Dashboard', url: path('admin_dashboard')},
    {label: 'Tipus de contingut', url: path('admin_content_type_index')},
    {label: 'Nou tipus'}
] %}
{% set page_desc = 'Crea una nova secció de contingut' %}

{% block page_title %}Nou tipus de contingut{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_content_type_index') }}" class="cyber-btn cyber-btn--projects">
    <i class="bi bi-arrow-left"></i> <span>Tornar</span>
</a>
{% endblock %}

{% block content %}
{% include 'admin/project/_project_header_bar.html.twig' %}
<div class="d2-body">
    <div class="cyber-card cyber-card--flush" data-anim="cyber-card">
        <div class="cyber-form-header">
            <div class="cyber-form-header-icon">
                <i class="bi bi-plus-circle"></i>
            </div>
            <div>
                <h2 class="cyber-section-title">Nou tipus de contingut</h2>
                <p class="cyber-section-desc">Defineix un nou tipus de contingut amb els seus camps personalitzats</p>
            </div>
        </div>

        <form method="post" class="cyber-form-body">
            <input type="hidden" name="_token" value="{{ csrf_token('content-type-new') }}">
            <div class="row mb-3">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="cyber-form-group mb-0">
                        <label class="cyber-form-label">Nom del tipus *</label>
                        <input type="text" name="name" class="cyber-form-input" id="nameInput" required placeholder="Notícies, Events...">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="cyber-form-group mb-0">
                        <label class="cyber-form-label">Slug * <span class="cyber-form-label__hint">(identificador únic)</span></label>
                        <input type="text" name="slug" class="cyber-form-input" id="slugInput" required placeholder="noticies, events...">
                    </div>
                </div>
            </div>

            <div class="cyber-form-group mb-3">
                <label class="cyber-form-label">Descripció</label>
                <textarea name="description" class="cyber-form-input" rows="2" placeholder="Escriu una descripció del tipus..."></textarea>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="cyber-form-group mb-0">
                        <label class="cyber-form-label">Projecte *</label>
                        <select name="project_id" class="cyber-form-input cyber-form-input--select" required>
                            <option value="">Selecciona un projecte</option>
                            {% for p in projects %}
                            <option value="{{ p.id }}">{{ p.user.name ?? 'Sense usuari' }} — {{ p.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <label class="s-toggle s-toggle--chk mb-0" style="--s-toggle-color:var(--s-accent)" for="ct-active">
                        <input type="checkbox" name="active" class="s-toggle__inp-cb" id="ct-active" checked value="1">
                        <span class="s-toggle__switch"></span>
                        <span class="s-toggle__icon"><i class="bi bi-check-circle"></i></span>
                        <span class="s-toggle__lbl-cb s-toggle__lbl-cb--off">Inactiu</span>
                        <span class="s-toggle__lbl-cb s-toggle__lbl-cb--on">Actiu</span>
                    </label>
                </div>
            </div>

            <hr class="form-divider my-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <label class="cyber-form-label cyber-form-label--sm mb-0">Camps del tipus</label>
                <button type="button" class="cyber-btn cyber-btn--compact cyber-btn--add-field" id="addFieldBtn">
                    <i class="bi bi-plus-lg"></i> <span class="cyber-btn__label">Afegir camp</span>
                </button>
            </div>

            <div id="fieldsContainer">
                <div class="s-field-group field-row mb-3">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-4">
                            <input type="text" name="field_name[]" class="cyber-form-input" placeholder="Nom del camp">
                        </div>
                        <div class="col-md-3">
                            <select name="field_type[]" class="cyber-form-input cyber-form-input--select field-type-select" data-field-type="toggle">
                                {% for type in fieldTypes %}
                                <option value="{{ type }}">{{ type }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-center">
                            <label class="s-toggle s-toggle--chk s-toggle--inline mb-0" style="--s-toggle-color:#ef4444">
                                <input type="checkbox" name="field_required[]" class="s-toggle__inp-cb" value="1">
                                <span class="s-toggle__switch"></span>
                                <span class="s-toggle__icon"><i class="bi bi-asterisk"></i></span>
                                <span class="s-toggle__lbl-cb s-toggle__lbl-cb--off">Opcional</span>
                                <span class="s-toggle__lbl-cb s-toggle__lbl-cb--on">Requerit</span>
                            </label>
                        </div>
                        <div class="col-md-2 text-end">
                            <button type="button" class="cyber-btn cyber-btn--icon cyber-btn--delete remove-field">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                    <div class="row field-options-wrap">
                        <div class="col-12 mt-2">
                            <textarea name="field_options[]" class="cyber-form-input" rows="2" placeholder="Una opció per línia&#10;Ex:&#10;Essencial&#10;Integral&#10;Master"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="form-divider my-4">
            <button type="submit" class="cyber-form-submit mt-2" data-anim="cyber-btn">
                <i class="bi bi-check-lg"></i> <span>Crear tipus</span>
            </button>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/content-type.js') }}?v={{ 'now'|date('U') }}"></script>
{% endblock %}
