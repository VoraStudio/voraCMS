{# _gallery_field.html.twig — reusable gallery/image field
   Params: fieldId, fieldType ('image'|'gallery'), value, mediaPaths, required #}
<div class="gallery-field" data-field-id="{{ fieldId }}">
    {% set inputId = 'file_' ~ fieldId ~ (fieldType == 'gallery' ? '_g' : '') %}
    {% set itemIds = value ? value|split(',') : [] %}

    <!-- Notion-style upload dropzone -->
    <div class="gallery-field__dropzone">
        <input type="file" name="field_{{ fieldId }}_files[]" id="{{ inputId }}" class="gallery-field__file-input" accept=".jpg,.jpeg,.webp,.avif" multiple>
        <label for="{{ inputId }}" class="gallery-field__label">
            <i class="bi bi-cloud-upload gallery-field__icon"></i>
            <p class="gallery-field__text">Arrossega fitxers o selecciona'ls</p>
            <span class="gallery-field__hint">JPG, WebP o AVIF · Màxim 1MB cadascuna</span>
        </label>
    </div>

    <input type="hidden" name="field_{{ fieldId }}" class="gallery-value" value="{{ value }}">

    <!-- Gallery previews (JS-compatible class names) -->
    <div class="gallery-previews">
        {% for gid in itemIds %}
        <div class="gallery-thumb" data-id="{{ gid }}">
            <img src="{{ mediaPaths[gid] ?? '' }}" alt="">
            <button type="button" class="remove-gallery-item" aria-label="Eliminar"><i class="bi bi-x"></i></button>
        </div>
        {% endfor %}
    </div>

    <!-- Media picker link -->
    <button type="button" class="gallery-field__pick-btn pick-media" data-field="{{ fieldId }}" data-multiple="true">
        <i class="bi bi-images"></i> Escull des de la mediateca
    </button>
</div>
