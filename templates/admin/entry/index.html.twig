{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ contentType.name }}{% endblock %}

{% block topbar_actions %}
<a href="{{ path('admin_entry_new', {slug: contentType.slug}) }}" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg"></i> Nova entrada
</a>
{% endblock %}

{% block content %}
<div class="d-flex align-items-center gap-3 mb-3">
    <span style="color:var(--s-text-secondary);font-size:0.8rem;">
        {{ contentType.entries|length }} entrades · {{ contentType.fields|length }} camps
    </span>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="width:48px;"></th>
                    <th>ID</th>
                    <th>Títol</th>
                    <th>Data</th>
                    <th>Estat</th>
                    <th>Idioma</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for entry in entries %}
                <tr>
                    <td>
                        {% set thumb = thumbnails[entry.id] ?? null %}
                        {% if thumb %}
                            <img src="{{ thumb }}" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:8px;display:block;">
                        {% else %}
                            <div style="width:40px;height:40px;border-radius:8px;background:rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;color:var(--s-text-secondary);font-size:0.7rem;">—</div>
                        {% endif %}
                    </td>
                    <td>{{ entry.id }}</td>
                    <td>
                        {% set title = '' %}
                        {% for fv in entry.fieldValues|sort((a, b) => a.fieldDefinition.sortOrder <=> b.fieldDefinition.sortOrder) %}
                            {% if fv.fieldDefinition.fieldType in ['text', 'textarea'] and fv.value and not title %}
                                {% set title = fv.value %}
                            {% endif %}
                        {% endfor %}
                        {% if title %}
                            {{ title|length > 40 ? title|slice(0, 40) ~ '...' : title }}
                        {% else %}
                            <span style="color:var(--s-text-secondary);font-style:italic;">Sense títol</span>
                        {% endif %}
                    </td>
                    <td>{{ entry.createdAt|date('d/m/Y H:i') }}</td>
                    <td>
                        {% if entry.status == 'published' %}
                            <span class="badge bg-success">Publicat</span>
                        {% elseif entry.status == 'draft' %}
                            <span class="badge bg-secondary">Esborrany</span>
                        {% else %}
                            <span class="badge" style="background:var(--s-danger);color:#fff;">Arxivat</span>
                        {% endif %}
                    </td>
                    <td>{{ entry.locale|upper }}</td>
                    <td class="text-end">
                        <a href="{{ path('admin_entry_edit', {id: entry.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('admin_entry_delete', {id: entry.id}) }}" style="display:inline" onsubmit="return confirm('Segur?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entry.id) }}">
                            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center py-4" style="color:var(--s-text-secondary);">No hi ha entrades encara.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
