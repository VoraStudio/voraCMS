{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ contentType.name }}{% endblock %}

{% block topbar_actions %}
<div class="topbar-actions-group">
    <a href="{{ path('admin_entry_new', {slug: contentType.slug}) }}" class="cyber-btn cyber-btn--projects">
        <i class="bi bi-plus-lg"></i> <span>Nova Entrada</span>
    </a>
    <a href="{{ path('admin_project_show', {id: contentType.project.id}) }}" class="cyber-btn cyber-btn--projects" title="Tornar al projecte">
        <i class="bi bi-folder2-open"></i> <span>Tornar al projecte</span>
    </a>
</div>
{% endblock %}

{% block content %}
{% include 'admin/components/_section_header.html.twig' with {
    title: contentType.name,
    description: contentType.description ?: 'Gestiona les entrades d\'aquesta secció',
    icon: 'bi-file-text',
    stats: [
        {value: entries|length, label: 'Total'},
        {value: entries|filter(e => e.active)|length, label: 'Actius', modifier: 'active'}
    ]
} %}

<div class="cyber-card cyber-card--table cyber-card--flush" data-anim="cyber-card">
    <table class="cyber-table">
        <thead>
            <tr>
                <th>Títol</th>
                <th>Data</th>
                <th>Estat</th>
                <th>Actiu</th>
                <th>Idioma</th>
                <th>Accions</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in entries %}
            {% set title = '' %}
            {% for fv in entry.fieldValues|sort((a, b) => a.fieldDefinition.sortOrder <=> b.fieldDefinition.sortOrder) %}
                {% if fv.fieldDefinition.fieldType in ['text', 'textarea'] and fv.value and not title %}
                    {% set title = fv.value %}
                {% endif %}
            {% endfor %}

            <tr class="cyber-row {{ entry.active ? 'row-active' : 'row-inactive' }}" data-anim="cyber-row">
                <td class="cyber-cell" data-label="Títol">
                    <div class="cyber-cell__content">
                        {% set thumb = thumbnails[entry.id] ?? null %}
                        {% if thumb %}
                            <img src="{{ thumb }}" alt="" class="cyber-cell__thumb">
                        {% else %}
                            <div class="cyber-cell__icon-placeholder">
                                <i class="bi bi-file-text"></i>
                            </div>
                        {% endif %}
                        <div>
                            <div class="cyber-cell__title">
                                {% if title %}
                                    {{ title|length > 50 ? title|slice(0, 50) ~ '...' : title }}
                                {% else %}
                                    <span class="cyber-cell__placeholder">Sense títol</span>
                                {% endif %}
                            </div>
                            <div class="cyber-cell__subtitle">ID {{ entry.id }}</div>
                        </div>
                    </div>
                </td>
                <td class="cyber-cell cyber-cell--date" data-label="Data">
                    {{ entry.createdAt|date('d/m/Y H:i') }}
                </td>
                <td class="cyber-cell" data-label="Estat">
                    <span class="cyber-status">
                        {% if entry.status == 'published' %}
                            <span class="cyber-status-dot cyber-status-dot--active"></span>
                            <span class="cyber-status-text">Publicat</span>
                        {% elseif entry.status == 'draft' %}
                            <span class="cyber-status-dot cyber-status-dot--draft"></span>
                            <span class="cyber-status-text--draft">No publicat</span>
                        {% else %}
                            <span class="cyber-status-dot cyber-status-dot--archived"></span>
                            <span class="cyber-status-text--archived">Arxivat</span>
                        {% endif %}
                    </span>
                </td>
                <td class="cyber-cell cyber-cell--status" data-label="Actiu">
                    {% include 'admin/components/_status.html.twig' with {active: entry.active} %}
                </td>
                <td class="cyber-cell cyber-cell--locale" data-label="Idioma">
                    {{ entry.locale|upper }}
                </td>
                <td class="cyber-cell" data-label="Accions">
                    <div class="cyber-actions">
                        <a href="{{ path('admin_entry_preview', {id: entry.id}) }}"
                           class="cyber-btn cyber-btn--projects"
                           title="Veure">
                            <i class="bi bi-eye"></i> <span>Veure</span>
                        </a>

                        <span class="cyber-actions-divider"></span>

                        {% include 'admin/components/_toggle_btn.html.twig' with {
                            formId: 'tact-entry-' ~ entry.id,
                            csrfToken: csrf_token('toggle-active-' ~ entry.id),
                            route: path('admin_entry_toggle_active', {id: entry.id}),
                            active: entry.active
                        } %}

                        <a href="{{ path('admin_entry_edit', {id: entry.id}) }}"
                           class="cyber-btn cyber-btn--icon cyber-btn--edit"
                           title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <form method="post" action="{{ path('admin_entry_delete', {id: entry.id}) }}" class="cyber-form--inline"
                              id="del-entry-{{ entry.id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entry.id) }}">
                            <button type="button"
                                    class="cyber-btn cyber-btn--icon cyber-btn--delete"
                                    title="Eliminar"
                                    data-confirm="Segur que vols eliminar aquesta entrada?"
                                    data-form="del-entry-{{ entry.id }}">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="cyber-empty">
                    <div class="cyber-empty-icon"><i class="bi bi-file-text"></i></div>
                    <p class="cyber-empty-text">No hi ha entrades encara</p>
                    <a href="{{ path('admin_entry_new', {slug: contentType.slug}) }}" class="cyber-btn-primary cyber-btn--action">
                        <i class="bi bi-plus-lg"></i> <span>Crear primera entrada</span>
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
