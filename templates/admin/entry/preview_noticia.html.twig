<!DOCTYPE html>
<html lang="ca"{% set theme = app.request.query.get('theme', 'dark') %} data-theme="{{ theme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Preview: {{ data.titul|default(data.titol|default('Notícia')) }}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --color-black: #000000;
            --color-white: #FFFFFF;
            --color-cream: #F5ECE5;
            --color-wine: #722F37;      
            --color-mauve: #debcb0;
            
            --font-primary: 'Syne', sans-serif;
            --font-secondary: 'Plus Jakarta Sans', sans-serif;
            
            --space-s: 16px;
            --space-m: 24px;
            --space-l: 32px;
            --space-xl: 48px;
            --space-xxl: 64px;

            /* Modo Claro (Default) */
            --page-bg: #f5f5f7;
            --modal-bg: #ffffff;
            --modal-border: #e0e0e0;
            --modal-text-primary: #111111;
            --modal-text-secondary: #555555;
            --modal-text-muted: #333333;
            --modal-range-label: rgba(0, 0, 0, 0.4);
            --modal-pill-bg: #e8f0fe;
            --modal-pill-border: #c5d9f5;
            --modal-pill-text: #1a2a4a;
            --modal-pill-svg: #4a7ab5;
            --modal-shadow: rgba(0, 0, 0, 0.15);
            --modal-gallery-bg: #f0f0f0;
            --modal-tag-bg: rgba(0, 0, 0, 0.7);
            --modal-tag-text: #ffffff;
            --modal-tag-border: rgba(255, 255, 255, 0.15);
        }

        :root[data-theme="dark"] {
                /* Modo Oscuro */
                --page-bg: #000000;
                --modal-bg: #121212;
                --modal-border: rgba(255, 255, 255, 0.25);
                --modal-text-primary: #ffffff;
                --modal-text-secondary: var(--color-mauve);
                --modal-text-muted: rgba(255, 255, 255, 0.8);
                --modal-range-label: rgba(255, 255, 255, 0.4);
                --modal-pill-bg: rgba(255, 255, 255, 0.06);
                --modal-pill-border: rgba(255, 255, 255, 0.25);
                --modal-pill-text: rgba(255, 255, 255, 0.85);
                --modal-pill-svg: rgba(255, 255, 255, 0.6);
                --modal-shadow: rgba(0, 0, 0, 0.6);
                --modal-gallery-bg: rgba(255, 255, 255, 0.02);
                --modal-tag-bg: rgba(255, 255, 255, 0.12);
                --modal-tag-text: #ffffff;
                --modal-tag-border: rgba(255, 255, 255, 0.25);
            }

        /* Reset & General */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--page-bg);
            color: var(--modal-text-primary);
            font-family: var(--font-secondary);
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
            padding: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        #noticia-main {
            width: 100%;
            max-width: 800px;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* --- ESTILO 09: TAGS + PÍLDORAS --- */
        .m9 {
            background: var(--modal-bg);
            border: 1px solid var(--modal-border);
            width: 100%;
            height: 100%;
            border-radius: 24px;
            overflow: clip;
            display: flex;
            flex-direction: column;
            transition: background 0.3s ease, border-color 0.3s ease;
        }

        .m9-hero {
            width: 100%;
            height: 140px;
            background-size: cover;
            background-position: center;
            padding: 16px 20px;
            display: flex;
            align-items: flex-start;
            gap: 8px;
            flex-wrap: wrap;
            flex-shrink: 0;
            position: relative;
        }

        .m9-tag {
            background: var(--modal-tag-bg);
            color: var(--modal-tag-text);
            font-size: 10px;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 100px;
            border: 1px solid var(--modal-tag-border);
            display: inline-flex;
            align-items: center;
            gap: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            position: relative;
            z-index: 2;
        }

        .m9-body {
            padding: 20px 20px 32px;
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
            scrollbar-width: none;
            -ms-overflow-style: none;
            background: var(--modal-bg);
            transition: background 0.3s ease;
        }

        .m9-body::-webkit-scrollbar {
            display: none;
        }

        .m9 h2 {
            font-family: var(--font-secondary);
            font-size: clamp(1.5rem, 3vw, 1.45rem);
            font-weight: 700;
            color: var(--modal-text-primary);
            line-height: 1.25;
            margin: 0;
            transition: color 0.3s ease;
        }

        .m9 h3 {
            font-size: 12px;
            font-weight: 400;
            color: var(--modal-text-secondary);
            line-height: 1.4;
            margin: 0;
            transition: color 0.3s ease;
        }

        .m9-range {
            font-family: var(--font-secondary);
            font-size: 11px;
            color: var(--modal-text-secondary);
            transition: color 0.3s ease;
        }

        .m9-range span {
            margin-top:0.5rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--modal-range-label);
            font-size: 9px;
            letter-spacing: 1px;
            margin-right: 6px;
            transition: color 0.3s ease;
        }

        .m9-pills {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .m9-pill {
            font-size: 11px;
            color: var(--modal-pill-text);
            padding: 4px 12px;
            border-radius: 100px;
            border: 1px solid var(--modal-pill-border);
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: var(--modal-pill-bg);
            transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
        }

        .m9-pill svg {
            color: var(--modal-pill-svg);
            flex-shrink: 0;
            transition: color 0.3s ease;
        }

        .m9-text {
            font-size: 14px;
            color: var(--modal-text-muted);
            line-height: 1.8;
            margin: 0;
            transition: color 0.3s ease;
        }

        .m9-gallery {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: 100px;
            gap: 10px;
            flex-shrink: 0;
            margin-top: 20px;
            width: 100%;
        }

        .m9-gallery div {
            background-size: cover;
            background-position: center;
            background-color: var(--modal-gallery-bg);
            border-radius: 12px;
            transition: transform 0.3s ease, background-color 0.3s ease;
        }

        .m9-gallery div:hover {
            transform: scale(1.015);
        }

        .m9-gallery-placeholder {
            border: 1px dashed var(--modal-border);
            background-color: var(--modal-gallery-bg);
        }

        .m9-gallery div:nth-child(1) {
            grid-column: span 2;
            grid-row: span 2;
            height: 210px;
        }

        .m9-gallery div:nth-child(2) {
            grid-column: span 2;
            grid-row: span 1;
            height: 100px;
        }

        .m9-gallery div:nth-child(3) {
            grid-column: span 1;
            grid-row: span 1;
            height: 100px;
        }

        .m9-gallery div:nth-child(4) {
            grid-column: span 1;
            grid-row: span 1;
            height: 100px;
        }

        .noticia-body {
            font-family: var(--font-secondary);
            font-size: clamp(0.95rem, calc(0.5vw + 0.7rem), 1.1rem);
            line-height: 1.1;
            color: var(--modal-text-muted);
            transition: color 0.3s ease;
        }

        .noticia-body p {
            margin-bottom: 16px;
        }

        .noticia-body p:last-child {
            margin-bottom: 0;
        }

        /* --- LIGHTBOX MODAL --- */
        :root {
            --lightbox-bg: rgba(255, 255, 255, 0.96);
            --lightbox-color: #111111;
            --lightbox-btn-bg: rgba(0, 0, 0, 0.05);
            --lightbox-btn-hover-bg: rgba(0, 0, 0, 0.1);
        }
        :root[data-theme="dark"] {
                --lightbox-bg: rgba(10, 10, 10, 0.97);
                --lightbox-color: #ffffff;
                --lightbox-btn-bg: rgba(255, 255, 255, 0.08);
                --lightbox-btn-hover-bg: rgba(255, 255, 255, 0.15);
        }

        .vt-lightbox {
            position: fixed;
            inset: 0;
            z-index: 99999;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--lightbox-bg);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        .vt-lightbox.active {
            opacity: 1;
            pointer-events: all;
        }

        .vt-lightbox-content {
            position: relative;
            max-width: 85%;
            max-height: 85%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .vt-lightbox-img {
            max-width: 100%;
            max-height: 80vh;
            object-fit: contain;
            border-radius: 12px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
            transform: scale(0.95);
            transition: transform 0.3s ease;
        }

        .vt-lightbox.active .vt-lightbox-img {
            transform: scale(1);
        }

        .vt-lightbox-close,
        .vt-lightbox-prev,
        .vt-lightbox-next {
            position: absolute;
            background: var(--lightbox-btn-bg);
            border: none;
            color: var(--lightbox-color);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10;
            transition: all 0.2s ease;
        }

        .vt-lightbox-close:hover,
        .vt-lightbox-prev:hover,
        .vt-lightbox-next:hover {
            background: var(--lightbox-btn-hover-bg);
            transform: scale(1.05);
        }

        .vt-lightbox-close {
            top: 24px;
            right: 24px;
        }

        .vt-lightbox-prev {
            left: 24px;
        }

        .vt-lightbox-next {
            right: 24px;
        }
    </style>
</head>
<body>
    {% set imgUrl = null %}
    {% if data.imatge is defined and data.imatge[0] is defined %}
        {% set imgUrl = asset(data.imatge[0].url) %}
    {% endif %}

    {% set formattedDate = '' %}
    {% if data.data is defined and data.data is not empty %}
        {% set formattedDate = data.data|date('d/m/Y') %}
    {% elseif data.date is defined and data.date is not empty %}
        {% set formattedDate = data.date|date('d/m/Y') %}
    {% elseif entry.publishedAt %}
        {% set formattedDate = entry.publishedAt|date('d/m/Y') %}
    {% endif %}

    {% set locationText = '' %}
    {% if data.location is defined and data.location is not empty %}
        {% set locationText = data.location %}
    {% elseif data.ubicacio is defined and data.ubicacio is not empty %}
        {% set locationText = data.ubicacio %}
    {% endif %}

    <main id="noticia-main">
        <div class="m9">
            <div class="m9-hero" {% if imgUrl %}style="background-image: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.6)), url('{{ imgUrl }}');"{% else %}style="background: linear-gradient(135deg, #e24b4a 0%, #6b1a1a 100%);"{% endif %}>
                {% if data.categoria is defined and data.categoria is not empty %}
                    <span class="m9-tag">{{ data.categoria }}</span>
                {% endif %}
                <span class="m9-tag">Notícia</span>
            </div>
            <div class="m9-body">
                <h2>{{ data.titul|default(data.titol|default('Sense Títol')) }}</h2>
                {% if data.subtitol is defined and data.subtitol is not empty %}
                    <h3>{{ data.subtitol }}</h3>
                {% endif %}
                
                {% if data.rang_de_dates is defined and data.rang_de_dates is not empty %}
                    {% set range = data.rang_de_dates %}
                    {% if range is not iterable %}
                        {% set range = range|json_decode %}
                    {% endif %}
                    {% if range.start is defined and range.start is not empty %}
                        <div class="m9-range">
                            <span>Rang de dates:</span> 
                            {{ range.start|date('d/m/Y') }} &middot; {{ range.end|date('d/m/Y') }}
                        </div>
                    {% endif %}
                {% endif %}

                <div class="m9-pills">
                    {% if formattedDate %}
                        <span class="m9-pill">
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            {{ formattedDate }}
                        </span>
                    {% endif %}
                    {% if locationText %}
                        <span class="m9-pill">
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            {{ locationText }}
                        </span>
                    {% endif %}
                </div>

                <div class="m9-text noticia-body">
                    {{ data.descripcio|default('Sense contingut.')|raw }}
                </div>

                <div class="m9-gallery">
                    {% set galeria = data.galeria|default(data.imatges|default([])) %}
                    {% for i in 0..3 %}
                        {% if galeria[i] is defined %}
                            <div style="background-image: url('{{ asset(galeria[i].url) }}');"></div>
                        {% else %}
                            <div class="m9-gallery-placeholder"></div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </main>

    <!-- Lightbox Markup -->
    <div class="vt-lightbox" id="gallery-lightbox" aria-hidden="true">
        <button class="vt-lightbox-close" aria-label="Tancar">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <button class="vt-lightbox-prev" aria-label="Anterior">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="vt-lightbox-content">
            <img class="vt-lightbox-img" src="" alt="Galeria">
        </div>
        <button class="vt-lightbox-next" aria-label="Següent">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var galleryContainer = document.querySelector('.m9-gallery');
            if (!galleryContainer) return;

            var images = [];
            var currentIndex = 0;
            var lightbox = document.getElementById('gallery-lightbox');
            var lightboxImg = lightbox.querySelector('.vt-lightbox-img');
            var closeBtn = lightbox.querySelector('.vt-lightbox-close');
            var prevBtn = lightbox.querySelector('.vt-lightbox-prev');
            var nextBtn = lightbox.querySelector('.vt-lightbox-next');

            // Collect all valid images from the grid
            var items = galleryContainer.querySelectorAll('div');
            items.forEach(function (item, index) {
                var bg = item.style.backgroundImage;
                if (bg && bg !== 'none' && !bg.includes('rgba')) {
                    // Extract URL
                    var url = bg.replace(/^url\(["']?/, '').replace(/["']?\)$/, '');
                    images.push(url);

                    // Add click event
                    item.style.cursor = 'pointer';
                    item.addEventListener('click', function () {
                        currentIndex = images.indexOf(url);
                        openLightbox();
                    });
                }
            });

            function openLightbox() {
                updateImage();
                lightbox.classList.add('active');
                lightbox.setAttribute('aria-hidden', 'false');
            }

            function closeLightbox() {
                lightbox.classList.remove('active');
                lightbox.setAttribute('aria-hidden', 'true');
            }

            function updateImage() {
                if (images.length === 0) return;
                lightboxImg.src = images[currentIndex];
            }

            function showPrev() {
                if (images.length === 0) return;
                currentIndex = (currentIndex - 1 + images.length) % images.length;
                updateImage();
            }

            function showNext() {
                if (images.length === 0) return;
                currentIndex = (currentIndex + 1) % images.length;
                updateImage();
            }

            closeBtn.addEventListener('click', closeLightbox);
            prevBtn.addEventListener('click', function(e) { e.stopPropagation(); showPrev(); });
            nextBtn.addEventListener('click', function(e) { e.stopPropagation(); showNext(); });
            lightbox.addEventListener('click', closeLightbox);
            lightboxImg.addEventListener('click', function(e) { e.stopPropagation(); });

            document.addEventListener('keydown', function (e) {
                if (!lightbox.classList.contains('active')) return;
                if (e.key === 'ArrowLeft') {
                    showPrev();
                } else if (e.key === 'ArrowRight') {
                    showNext();
                } else if (e.key === 'Escape') {
                    closeLightbox();
                }
            });
        });
    </script>
</body>
</html>
