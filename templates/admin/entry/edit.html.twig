{% extends 'admin/layout.html.twig' %}

{% block page_title %}
{% set entryTitle = '' %}
{% for fv in entry.fieldValues|sort((a, b) => a.fieldDefinition.sortOrder <=> b.fieldDefinition.sortOrder) %}
    {% if fv.fieldDefinition.fieldType in ['text', 'textarea'] and fv.value and not entryTitle %}
        {% set entryTitle = fv.value %}
    {% endif %}
{% endfor %}
{{ entryTitle ?: (contentType.name ~ ' #' ~ entry.id) }}
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
{% endblock %}

{% block topbar_actions %}
<div class="topbar-actions-group">
    {% if contentType.slug in ['noticia', 'event', 'artistes_victoria_taylor'] %}
        {% if contentType.slug in ['artistes_victoria_taylor'] %}
            <a href="{{ path('admin_entry_preview', {id: entry.id}) }}" class="cyber-btn cyber-btn--projects js-preview-newtab">
                <i class="bi bi-eye"></i> <span>Previsualitzar</span>
            </a>
        {% else %}
            <a href="{{ path('admin_entry_preview', {id: entry.id}) }}" class="cyber-btn cyber-btn--projects js-preview-modal" data-type="{{ contentType.slug }}">
                <i class="bi bi-eye"></i> <span>Previsualitzar</span>
            </a>
        {% endif %}
    {% endif %}
    <a href="{{ path('admin_entry_by_type', {slug: contentType.slug}) }}" class="cyber-btn cyber-btn--projects">
        <i class="bi bi-arrow-left"></i> <span>Tornar</span>
    </a>
</div>
{% endblock %}

{% block content %}
<div class="card">
    <div class="card-body">
        <form method="post" id="entryForm" enctype="multipart/form-data" novalidate>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Estat</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="draft" {% if entry.status == 'draft' %}selected{% endif %}>No publicat</option>
                        <option value="published" {% if entry.status == 'published' %}selected{% endif %}>Publicat</option>
                        <option value="archived" {% if entry.status == 'archived' %}selected{% endif %}>Arxivat</option>
                    </select>
                </div>
            </div>

            <hr class="entry-fields-divider">
            <div class="entry-fields-grid">
            {% for field in contentType.fields %}
            {% set fv = entry.fieldValues|filter(v => v.fieldDefinition.id == field.id)|first %}
            {% set val = fv ? fv.value : '' %}
            <div class="mb-3 field-{{ field.fieldType }}">
                <label class="form-label">
                    {{ field.name }}
                    {% if field.required %}<span class="form-label__required">*</span>{% endif %}
                </label>

                {% if field.fieldType == 'richtext' %}
                {% include 'admin/components/_quill_field.html.twig' with {
                    fieldId: field.id,
                    value: val,
                    required: field.required
                } %}

                {% elseif field.fieldType == 'textarea' %}
                <textarea name="field_{{ field.id }}" class="form-control" rows="4" {% if field.required %}required{% endif %}>{{ val }}</textarea>

                {% elseif field.fieldType == 'date' %}
                <input type="datetime-local" name="field_{{ field.id }}" class="form-control" value="{{ val }}" {% if field.required %}required{% endif %}>

                {% elseif field.fieldType == 'date_range' %}
                {% set range = val ? val|json_decode : null %}
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label small">Inici</label>
                        <input type="datetime-local" name="field_{{ field.id }}_start" class="form-control" value="{{ range.start ?? '' }}" {% if field.required %}required{% endif %}>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Fi</label>
                        <input type="datetime-local" name="field_{{ field.id }}_end" class="form-control" value="{{ range.end ?? '' }}" {% if field.required %}required{% endif %}>
                    </div>
                </div>

                {% elseif field.fieldType == 'boolean' %}
                <div class="form-check">
                    <input type="checkbox" name="field_{{ field.id }}" class="form-check-input" value="1" {% if val %}checked{% endif %}>
                    <label class="form-check-label small">Sí</label>
                </div>

                {% elseif field.fieldType == 'number' %}
                <input type="number" name="field_{{ field.id }}" class="form-control" step="any" value="{{ val }}" {% if field.required %}required{% endif %}>

                {% elseif field.fieldType == 'email' %}
                <input type="email" name="field_{{ field.id }}" class="form-control" value="{{ val }}" {% if field.required %}required{% endif %}>

                {% elseif field.fieldType == 'url' %}
                <input type="url" name="field_{{ field.id }}" class="form-control" value="{{ val }}" {% if field.required %}required{% endif %}>

                {% elseif field.fieldType == 'color' %}
                <input type="color" name="field_{{ field.id }}" class="form-control form-control-color" value="{{ val ?: '#000000' }}">

                {% elseif field.fieldType == 'image' %}
                {% include 'admin/components/_gallery_field.html.twig' with {
                    fieldId: field.id,
                    fieldType: 'image',
                    value: val,
                    mediaPaths: mediaPaths
                } %}

                {% elseif field.fieldType == 'gallery' %}
                {% include 'admin/components/_gallery_field.html.twig' with {
                    fieldId: field.id,
                    fieldType: 'gallery',
                    value: val,
                    mediaPaths: mediaPaths
                } %}

                {% elseif field.fieldType == 'repeater' %}
                {% include 'admin/components/_repeater_field.html.twig' with {
                    fieldId: field.id,
                    value: val,
                    required: field.required
                } %}

                {% elseif field.fieldType == 'select' %}
                <select name="field_{{ field.id }}" class="form-control" {% if field.required %}required{% endif %}>
                    <option value="">Selecciona...</option>
                    {% set options = field.helpText ? field.helpText|split('\n')|map(o => o|trim)|filter(o => o) : [] %}
                    {% for opt in options %}
                    <option value="{{ opt }}" {% if val == opt %}selected{% endif %}>{{ opt }}</option>
                    {% endfor %}
                </select>

                {% elseif field.fieldType == 'youtube' %}
                <div class="input-group">
                    <span class="input-group-text input-group-text--sm"><i class="bi bi-youtube"></i></span>
                    <input type="url" name="field_{{ field.id }}" class="form-control youtube-input" value="{{ val }}" placeholder="https://youtube.com/watch?v=..." {% if field.required %}required{% endif %}>
                </div>
                <div class="youtube-preview mt-2 {% if not val %}d-none{% endif %}">
                    <div class="ratio ratio-16x9 rounded overflow-hidden youtube-preview__frame">
                        <iframe src="" allowfullscreen loading="lazy"></iframe>
                    </div>
                </div>

                {% else %}
                <input type="text" name="field_{{ field.id }}" class="form-control" value="{{ val }}" {% if field.required %}required{% endif %}>
                {% endif %}

                {% if field.helpText %}
                <small class="field-help-text">{{ field.helpText }}</small>
                {% endif %}
            </div>
            {% endfor %}
            </div>

            <hr class="entry-fields-divider--top">
            <button type="submit" class="btn btn-primary w-100"><span>Guardar canvis</span></button>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<div id="entryFormConfig"
     data-media-picker-url="{{ path('admin_media_picker') }}?field=__FIELD_ID__&amp;project_id={{ contentType.project.id ?? '' }}"
     style="display:none;"></div>
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script src="{{ asset('js/entry-form.js') }}"></script>
{% endblock %}
